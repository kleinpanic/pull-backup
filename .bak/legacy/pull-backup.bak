#!/usr/bin/env python3
"""
pull-backup: Pull backups over SSH (WireGuard), snapshot+retention.

Key behavior:
- Resumes safely by keeping a persistent tag in snapshots/.inprogress-<device>/.run-tag
  so retries/restarts keep writing into the same in-progress snapshot.
- Handles broken pipes / ssh timeouts by:
  - waiting up to --reconnect-grace seconds for SSH to come back
  - retrying up to --attempts times
  - then moving on to the next job
- Handles SIGINT/SIGTERM cleanly (systemd stop, Ctrl+C): forwards signal to rsync
  process group, leaves partials, and exits without a Python traceback.
- Won't explode with an ugly traceback if the backup filesystem is missing/stale;
  instead prints a single [fatal] message and exits nonzero.

Layout:
  /srv/storage/backups/<class>/<device>/
    snapshots/
      current -> <tag>
      <tag>/...
      .inprogress-<device>/... (left behind if interrupted/failed; reused on resume)
    logs/
      backup-<device>-<tag>.log
  /srv/storage/backups/quarantined/<class>/<device>/<tag>/...
  /var/lib/pull-backup/state/<device>.failure   (state now OFF the backup mount)
  /run/pull-backup/lock                         (lock now in RuntimeDirectory)
"""

from __future__ import annotations

import argparse
import datetime as dt
import errno
import fcntl
import os
import shlex
import shutil
import signal
import subprocess
import sys
import time
from dataclasses import dataclass
from pathlib import Path
from typing import Any, Optional, Tuple


# ----------------------------
# FS error helpers
# ----------------------------

_FS_BAD_ERRNOS = {errno.ENODEV, errno.ESTALE, errno.EIO}

def _is_bad_fs_error(e: BaseException) -> bool:
    return isinstance(e, OSError) and getattr(e, "errno", None) in _FS_BAD_ERRNOS

def _bad_fs(msg: str) -> RuntimeError:
    return RuntimeError(msg)

def _safe_exists(p: Path, *, context: str) -> bool:
    try:
        return p.exists()
    except OSError as e:
        if _is_bad_fs_error(e):
            raise _bad_fs(f"backup filesystem not available while checking {context}: {p} ({e})")
        raise

def _safe_is_dir(p: Path, *, context: str) -> bool:
    try:
        return p.is_dir()
    except OSError as e:
        if _is_bad_fs_error(e):
            raise _bad_fs(f"backup filesystem not available while checking {context}: {p} ({e})")
        raise


# ----------------------------
# TOML loading
# ----------------------------

def load_toml(path: Path) -> dict[str, Any]:
    data = path.read_bytes()
    try:
        import tomllib  # py3.11+
        return tomllib.loads(data.decode("utf-8"))
    except Exception:
        try:
            import tomli  # type: ignore
            return tomli.loads(data.decode("utf-8"))
        except Exception as e:
            raise RuntimeError(f"Failed to parse TOML: {path} ({e})")


# ----------------------------
# Time helpers
# ----------------------------

def utc_now() -> dt.datetime:
    return dt.datetime.now(dt.timezone.utc)

def utc_tag() -> str:
    return utc_now().strftime("%Y%m%d-%H%M%SZ")

def iso_wd_and_name() -> Tuple[str, str]:
    now = utc_now()
    return str(now.isoweekday()), now.strftime("%a")  # "1".."7", "Mon"


# ----------------------------
# Schedule matching
# ----------------------------

def when_matches_today(when: str) -> bool:
    when = (when or "").strip().strip('"').strip("'")
    if when == "" or when == "*" or when.lower() == "daily":
        return True
    iso, name = iso_wd_and_name()
    parts = [p.strip() for p in when.split(",") if p.strip()]
    for p in parts:
        if p == iso or p == name or p.lower() == name.lower():
            return True
    return False


# ----------------------------
# Filesystem helpers
# ----------------------------

def ensure_under(root: Path, p: Path) -> None:
    root = root.resolve()
    p = p.resolve(strict=False)
    try:
        p.relative_to(root)
    except ValueError:
        raise RuntimeError(f"path escapes root: {p} (root={root})")

def safe_mkdir(path: Path, *, parents: bool = False) -> None:
    """
    mkdir that turns ENODEV/ESTALE/EIO into a clean RuntimeError.
    Also catches the pathlib "exist_ok -> is_dir()" code path which can raise ENODEV.
    """
    try:
        path.mkdir(parents=parents, exist_ok=True)
    except OSError as e:
        if _is_bad_fs_error(e):
            raise _bad_fs(f"backup filesystem not available at {path} (stale mount / missing device)")
        raise
    except Exception as e:
        # Some pathlib internal checks can surface as generic exceptions; re-check the path stat.
        try:
            _ = os.stat(str(path))
        except OSError as oe:
            if _is_bad_fs_error(oe):
                raise _bad_fs(f"backup filesystem not available at {path} (stale mount / missing device)")
        raise e

def statvfs_free_bytes(path: Path) -> int:
    try:
        st = os.statvfs(str(path))
    except OSError as e:
        if _is_bad_fs_error(e):
            raise _bad_fs(f"backup filesystem not available at {path} (stale mount / missing device)")
        raise
    return st.f_frsize * st.f_bavail

def assert_backups_root_ready(backups_root: Path) -> None:
    try:
        if not backups_root.exists():
            raise RuntimeError(f"backups root does not exist: {backups_root}")
        if not backups_root.is_dir():
            raise RuntimeError(f"backups root is not a directory: {backups_root}")
    except OSError as e:
        if _is_bad_fs_error(e):
            raise _bad_fs(f"backup filesystem not available at {backups_root} (stale mount / missing device)")
        raise
    _ = statvfs_free_bytes(backups_root)  # triggers stale-mount detection


def safe_list_dirs(snap_dir: Path) -> list[Path]:
    try:
        return [p for p in snap_dir.iterdir() if p.is_dir()]
    except OSError as e:
        if _is_bad_fs_error(e):
            raise _bad_fs(f"backup filesystem not available while listing {snap_dir} ({e})")
        raise


# ----------------------------
# SSH helpers
# ----------------------------

def ssh_cmd_base(ssh_config: Optional[Path]) -> list[str]:
    base = [
        "ssh",
        "-o", "BatchMode=yes",
        "-o", "ConnectTimeout=8",
        "-o", "ServerAliveInterval=5",
        "-o", "ServerAliveCountMax=2",
    ]
    if ssh_config and ssh_config.exists():
        base += ["-F", str(ssh_config)]
    return base

def run_quick(cmd: list[str]) -> tuple[int, str]:
    p = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
    return p.returncode, (p.stdout or "")

def ssh_ok(host: str, ssh_config: Optional[Path], log_fp) -> bool:
    cmd = ssh_cmd_base(ssh_config) + [host, "true"]
    rc, out = run_quick(cmd)
    if out.strip():
        log_fp.write(out)
        if not out.endswith("\n"):
            log_fp.write("\n")
        log_fp.flush()
    return rc == 0

def wait_for_ssh(host: str, ssh_config: Optional[Path], log_fp, grace_s: int, poll_s: int = 10) -> bool:
    """
    Wait up to grace_s for ssh to succeed. Returns True if reachable.
    """
    deadline = time.time() + max(0, grace_s)
    first = True
    while True:
        ok = ssh_ok(host, ssh_config, log_fp)
        if ok:
            return True
        now = time.time()
        if now >= deadline:
            return False
        if first:
            log_fp.write(f"[warn] ssh not reachable; waiting up to {grace_s}s for recovery...\n")
            log_fp.flush()
            first = False
        time.sleep(min(poll_s, int(deadline - now) + 1))


# ----------------------------
# Resumable run tag
# ----------------------------

def load_or_create_run_tag(inprog: Path) -> tuple[str, bool]:
    """
    Persist tag in inprog/.run-tag so repeated attempts resume and finalize the same snapshot name.
    Returns (tag, resumed).
    """
    tag_file = inprog / ".run-tag"
    if tag_file.exists():
        tag = tag_file.read_text(encoding="utf-8").strip()
        if tag:
            return tag, True

    tag = utc_tag()
    safe_mkdir(inprog, parents=True)
    tag_file.write_text(tag + "\n", encoding="utf-8")
    return tag, False

def clear_run_tag_in_tree(tree: Path) -> None:
    try:
        (tree / ".run-tag").unlink(missing_ok=True)
    except Exception:
        pass


# ----------------------------
# Logging + signal-safe runner
# ----------------------------

class _Runner:
    def __init__(self) -> None:
        self.child_pgid: Optional[int] = None
        self.signal_seen: Optional[int] = None

RUNNER = _Runner()

def _forward_signal(sig: int, _frame) -> None:
    RUNNER.signal_seen = sig
    if RUNNER.child_pgid is not None:
        try:
            os.killpg(RUNNER.child_pgid, sig)
        except ProcessLookupError:
            pass

def run_and_tee(cmd: list[str], log_fp, kill_grace_s: int = 20) -> tuple[int, Optional[int]]:
    """
    Returns (rc, signal_seen). signal_seen is the SIG* number if we got SIGINT/SIGTERM, else None.
    """
    old_int = signal.getsignal(signal.SIGINT)
    old_term = signal.getsignal(signal.SIGTERM)
    signal.signal(signal.SIGINT, _forward_signal)
    signal.signal(signal.SIGTERM, _forward_signal)

    rc = 1
    sig_seen: Optional[int] = None

    try:
        p = subprocess.Popen(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            bufsize=1,
            start_new_session=True,  # new process group
        )
        assert p.stdout
        RUNNER.child_pgid = os.getpgid(p.pid)
        RUNNER.signal_seen = None

        for line in p.stdout:
            sys.stdout.write(line)
            sys.stdout.flush()
            log_fp.write(line)
            log_fp.flush()

        rc = p.wait()
        sig_seen = RUNNER.signal_seen

        if sig_seen is not None:
            log_fp.write(f"[warn] received signal={sig_seen}; child rc={rc}\n")
            log_fp.flush()

        return rc, sig_seen

    finally:
        if RUNNER.child_pgid is not None:
            try:
                os.killpg(RUNNER.child_pgid, 0)
            except ProcessLookupError:
                pass
            else:
                try:
                    os.killpg(RUNNER.child_pgid, signal.SIGTERM)
                except ProcessLookupError:
                    pass
                t0 = time.time()
                while time.time() - t0 < kill_grace_s:
                    try:
                        os.killpg(RUNNER.child_pgid, 0)
                    except ProcessLookupError:
                        break
                    time.sleep(0.2)
                else:
                    try:
                        os.killpg(RUNNER.child_pgid, signal.SIGKILL)
                    except ProcessLookupError:
                        pass

        RUNNER.child_pgid = None
        RUNNER.signal_seen = None
        signal.signal(signal.SIGINT, old_int)
        signal.signal(signal.SIGTERM, old_term)


# ----------------------------
# Load-shedding
# ----------------------------

def wait_for_load(max_load: float, log_fp, poll_s: int = 10) -> None:
    if max_load <= 0:
        return
    warned = False
    while True:
        try:
            one, _five, _fifteen = os.getloadavg()
        except OSError:
            return
        if one <= max_load:
            return
        if not warned:
            log_fp.write(f"[warn] loadavg(1m)={one:.2f} > max_load={max_load:.2f}; waiting...\n")
            log_fp.flush()
            warned = True
        time.sleep(poll_s)


# ----------------------------
# State tracking (OFF backup mount)
# ----------------------------

def state_file(state_dir: Path, device: str) -> Path:
    return state_dir / f"{device}.failure"

def has_prior_failure(state_dir: Path, device: str) -> bool:
    # State dir is off the backup mount; still guard for safety.
    f = state_file(state_dir, device)
    try:
        return f.exists()
    except OSError as e:
        # Treat as "no prior failure" rather than crashing the backup run.
        return False

def mark_failure(state_dir: Path, device: str, reason: str) -> None:
    safe_mkdir(state_dir, parents=True)
    f = state_file(state_dir, device)
    count = 0
    if f.exists():
        try:
            count = int(f.read_text().strip().splitlines()[-1].split("=", 1)[1].strip())
        except Exception:
            count = 0
    count += 1
    f.write_text(
        f"last_time={utc_now().isoformat()}\nreason={reason}\ncount={count}\n",
        encoding="utf-8"
    )

def clear_failure(state_dir: Path, device: str) -> None:
    try:
        state_file(state_dir, device).unlink()
    except FileNotFoundError:
        pass


# ----------------------------
# Retention + log pruning
# ----------------------------

def prune_logs(log_dir: Path, keep_days: int) -> None:
    cutoff = utc_now() - dt.timedelta(days=keep_days)
    try:
        paths = list(log_dir.glob("backup-*.log"))
    except OSError as e:
        if _is_bad_fs_error(e):
            return
        raise
    for p in paths:
        try:
            mtime = dt.datetime.fromtimestamp(p.stat().st_mtime, tz=dt.timezone.utc)
            if mtime < cutoff:
                p.unlink()
        except Exception:
            pass

def retention(snap_dir: Path, quar_root: Path, keep: int, action: str, log_fp) -> None:
    snaps = sorted([p for p in safe_list_dirs(snap_dir) if p.name.startswith("20")])
    if len(snaps) <= keep:
        return
    old = snaps[: len(snaps) - keep]
    log_fp.write(f"[info] found {len(old)} snapshots older than keep={keep}\n")
    log_fp.flush()

    if action == "keep":
        log_fp.write("[info] action=keep (leaving older snapshots)\n")
        log_fp.flush()
        return

    if action == "quarantine":
        safe_mkdir(quar_root, parents=True)
        for d in old:
            dst = quar_root / d.name
            log_fp.write(f"[retention] quarantine {d.name} -> {dst}\n")
            log_fp.flush()
            d.rename(dst)
        return

    if action == "delete":
        for d in old:
            log_fp.write(f"[retention] delete {d.name}\n")
            log_fp.flush()
            shutil.rmtree(d)
        return

    raise RuntimeError(f"unknown retention action: {action}")


# ----------------------------
# Jobs config
# ----------------------------

@dataclass
class Job:
    device: str
    ssh: str
    path: str
    when: str
    description: str
    klass: str
    keep: int
    action: str

def parse_jobs(cfg: dict[str, Any], defaults: dict[str, Any]) -> list[Job]:
    jobs_raw = cfg.get("job", [])
    if not isinstance(jobs_raw, list):
        raise RuntimeError("jobs.toml must contain one or more [[job]] tables")
    out: list[Job] = []
    for j in jobs_raw:
        if not isinstance(j, dict):
            continue
        device = str(j.get("device", "")).strip()
        if not device:
            continue
        sshv = str(j.get("ssh", device)).strip()
        path = str(j.get("path", f"/home/{device}/")).strip()
        if not path.endswith("/"):
            path += "/"
        when = str(j.get("when", "daily")).strip()
        desc = str(j.get("description", "")).strip()
        klass = str(j.get("class", defaults["class"])).strip()
        keep = int(j.get("keep", defaults["keep"]))
        if keep < 1:
            keep = 1
        action = str(j.get("action", defaults["action"])).strip()
        out.append(Job(device, sshv, path, when, desc, klass, keep, action))
    return out


# ----------------------------
# Main
# ----------------------------

def main() -> int:
    ap = argparse.ArgumentParser(description="Pull backups over SSH (WireGuard), snapshot+retention.")
    ap.add_argument("--daemon", action="store_true", help="run scheduled jobs from jobs.toml")
    ap.add_argument("--jobs-file", default="/etc/pull-backup/jobs.toml")
    ap.add_argument("--backups-root", default="/srv/storage/backups")

    # State moved OFF the backup filesystem (prevents ENODEV crashes).
    ap.add_argument("--state-dir", default="/var/lib/pull-backup/state")

    ap.add_argument("--class", dest="klass", default="laptops")
    ap.add_argument("--keep", type=int, default=3)
    ap.add_argument("--action", choices=["quarantine", "delete", "keep"], default="quarantine")
    ap.add_argument("--log-days", type=int, default=30)
    ap.add_argument("--auto", action="store_true", help="allow destructive actions like retention delete")
    ap.add_argument("--deep-verify", action="store_true", help="force rsync --checksum")
    ap.add_argument("--ssh-config", default="/root/.ssh/config")

    # Lock file moved OFF the backup mount.
    ap.add_argument("--lock-file", default="/run/pull-backup/lock")

    # Retry / robustness knobs
    ap.add_argument("--attempts", type=int, default=3, help="max attempts per job on transient failures")
    ap.add_argument("--reconnect-grace", type=int, default=120, help="seconds to wait for SSH to recover before each attempt")
    ap.add_argument("--retry-sleep", type=int, default=0, help="seconds to sleep between failed attempts (after grace wait)")

    # Rsync knobs
    ap.add_argument("--rsync-timeout", type=int, default=120, help="rsync --timeout seconds (0 disables)")
    ap.add_argument("--bwlimit", type=int, default=0, help="rsync --bwlimit KB/s (0 disables)")
    ap.add_argument("--no-compress", action="store_true", help="disable rsync compression to reduce CPU")

    ap.add_argument("--strict-rsync", action="store_true", help="treat rsync exit codes 23/24 as hard failures (default: tolerate and finalize snapshot)")
    # Load shedding
    ap.add_argument("--max-load", type=float, default=4.0, help="wait until 1m loadavg <= this before starting rsync (0 disables)")
    ap.add_argument("--load-poll", type=int, default=10, help="seconds between loadavg checks")

    args = ap.parse_args()

    os.umask(0o077)

    backups_root = Path(args.backups_root).resolve()
    if str(backups_root) != "/srv/storage/backups":
        raise RuntimeError("backups-root must be exactly /srv/storage/backups")

    if not args.daemon:
        raise RuntimeError("Use --daemon (this tool is scheduler-driven).")

    # Locking (off-mount)
    lock_path = Path(args.lock_file)
    safe_mkdir(lock_path.parent, parents=True)

    with open(lock_path, "w") as lock_fp:
        fcntl.flock(lock_fp, fcntl.LOCK_EX)

        # Now verify backup fs is actually usable
        assert_backups_root_ready(backups_root)

        state_dir = Path(args.state_dir)
        cfg_path = Path(args.jobs_file)
        defaults = {"class": args.klass, "keep": args.keep, "action": args.action}

        cfg = load_toml(cfg_path)
        jobs = parse_jobs(cfg, defaults)

        ssh_config = Path(args.ssh_config) if args.ssh_config else None

        any_failed = False

        for job in jobs:
            if not when_matches_today(job.when):
                print(f"[daemon] skip {job.device} (when={job.when})")
                continue

            dev_dir = backups_root / job.klass / job.device
            snap_dir = dev_dir / "snapshots"
            log_dir = dev_dir / "logs"
            inprog = snap_dir / f".inprogress-{job.device}"
            quar_root = backups_root / "quarantined" / job.klass / job.device

            for p in (dev_dir, snap_dir, log_dir, inprog, quar_root):
                ensure_under(backups_root, p)

            safe_mkdir(log_dir, parents=True)
            safe_mkdir(snap_dir, parents=True)

            # Resumable tag
            tag, resumed = load_or_create_run_tag(inprog)

            log_file = log_dir / f"backup-{job.device}-{tag}.log"
            with open(log_file, "a" if log_file.exists() else "w", encoding="utf-8") as log_fp:
                src = f"{job.ssh}:{job.path}"

                if resumed:
                    log_fp.write(f"[resume] {utc_now().strftime('%F %T')} UTC tag={tag}\n")
                else:
                    log_fp.write(f"[start] {utc_now().strftime('%F %T')} UTC\n")

                log_fp.write(f"[info] device={job.device} class={job.klass} src={src}\n")
                if job.description:
                    log_fp.write(f"[info] description={job.description}\n")
                log_fp.write(
                    f"[info] keep={job.keep} action={job.action} auto={args.auto} "
                    f"attempts={args.attempts} grace={args.reconnect_grace}s "
                    f"rsync_timeout={args.rsync_timeout} max_load={args.max_load}\n"
                )
                log_fp.flush()

                # link-dest (from newest completed snapshot)
                snaps = sorted([p for p in safe_list_dirs(snap_dir) if p.name.startswith("20")])
                last_snap = snaps[-1] if snaps else None

                rsync_opts = [
                    "-aHAXx",
                    "--numeric-ids",
                    "--partial",
                    "--partial-dir=.rsync-partial",
                    "--info=stats2,progress2",
                    "--human-readable",
                ]
                if not args.no_compress:
                    rsync_opts.append("--compress")
                if args.rsync_timeout and args.rsync_timeout > 0:
                    rsync_opts.append(f"--timeout={args.rsync_timeout}")
                if args.bwlimit and args.bwlimit > 0:
                    rsync_opts.append(f"--bwlimit={args.bwlimit}")

                deep = args.deep_verify or has_prior_failure(state_dir, job.device)
                if deep:
                    rsync_opts.append("--checksum")
                    log_fp.write("[info] deep-verify enabled (--checksum)\n")
                    log_fp.flush()

                if last_snap:
                    rsync_opts.append(f"--link-dest={last_snap}")

                safe_mkdir(inprog, parents=True)

                ssh_str = "ssh -o BatchMode=yes -o ConnectTimeout=8 -o ServerAliveInterval=5 -o ServerAliveCountMax=2"
                if ssh_config and ssh_config.exists():
                    ssh_str += f" -F {shlex.quote(str(ssh_config))}"

                cmd = ["rsync"] + rsync_opts + ["-e", ssh_str, src, str(inprog) + "/"]

                # Treat "partial transfer due to error" as a *soft* success by default:
                # - we still finalize the snapshot (better than nothing)
                # - we leave a failure marker so next run can deep-verify (--checksum)
                soft_success_rcs = set() if args.strict_rsync else {23, 24}

                # rsync transient exit codes from official rsync manpage EXIT VALUES:
                # 12 protocol stream, 23 partial transfer, 30 timeout send/receive, 35 daemon timeout.
                #transient_rcs = {12, 23, 30, 35, 255}  # 255 is typically ssh/remote-shell failure.
                transient_rcs = {12, 30, 35, 255}


                attempt = 0
                succeeded = False
                soft_succeeded = False

                while attempt < max(1, args.attempts):
                    attempt += 1

                    wait_for_load(args.max_load, log_fp, poll_s=max(1, args.load_poll))

                    if not wait_for_ssh(job.ssh, ssh_config, log_fp, grace_s=args.reconnect_grace, poll_s=10):
                        log_fp.write(f"[warn] attempt={attempt}: ssh still unreachable after grace; giving up this attempt\n")
                        log_fp.flush()
                        if args.retry_sleep > 0:
                            time.sleep(args.retry_sleep)
                        continue

                    log_fp.write("[run] " + f"attempt={attempt} " + " ".join(shlex.quote(c) for c in cmd) + "\n")
                    log_fp.flush()

                    rc, sig_seen = run_and_tee(cmd, log_fp)

                    if sig_seen is not None or rc == 20:
                        log_fp.write(f"[fail] interrupted (rc={rc}); leaving partials in {inprog} for resume\n")
                        log_fp.flush()
                        mark_failure(state_dir, job.device, "interrupted")
                        prune_logs(log_dir, args.log_days)
                        any_failed = True
                        break

                    if rc == 0:
                        succeeded = True
                        break

                    # Soft-success: finalize snapshot but remember it was imperfect.
                    # Code 23 is "partial transfer due to error" (permissions, xattrs, etc.),
                    # and code 24 is commonly "vanished files" during transfer. :contentReference[oaicite:1]{index=1}
                    # We do NOT retry these by default; retrying won't fix perms/xattr issues.
                    if rc in soft_success_rcs:
                        log_fp.write(
                            f"[warn] rsync rc={rc} (partial transfer). Treating as SOFT-SUCCESS: "
                            f"snapshot will be finalized but may be incomplete. "
                            f"Failure marker kept to force deep-verify next run.\n"
                        )
                        log_fp.flush()
                        mark_failure(state_dir, job.device, f"soft_rsync_rc_{rc}")
                        succeeded = True
                        soft_succeeded = True
                        break

                    if rc in transient_rcs:
                        log_fp.write(f"[warn] transient rsync failure rc={rc}; will retry (attempt {attempt}/{args.attempts})\n")
                        log_fp.flush()
                        if args.retry_sleep > 0:
                            time.sleep(args.retry_sleep)
                        continue

                    log_fp.write(f"[fail] non-transient rsync rc={rc}; leaving partials in {inprog}\n")
                    log_fp.flush()
                    mark_failure(state_dir, job.device, f"rsync_rc_{rc}")
                    prune_logs(log_dir, args.log_days)
                    any_failed = True
                    break

                if not succeeded:
                    if not has_prior_failure(state_dir, job.device):
                        mark_failure(state_dir, job.device, "unreachable_or_transient_failures")
                    any_failed = True
                    continue

                # Finalize snapshot
                final = snap_dir / tag
                if final.exists():
                    shutil.rmtree(final)

                inprog.rename(final)
                clear_run_tag_in_tree(final)

                cur = snap_dir / "current"
                try:
                    if cur.is_symlink() or cur.exists():
                        cur.unlink()
                except FileNotFoundError:
                    pass
                cur.symlink_to(final)

                log_fp.write(f"[ok] finalized snapshot: {final}\n")
                log_fp.flush()

                # retention
                if job.action == "delete" and not args.auto:
                    log_fp.write("[warn] action=delete but --auto not set; skipping deletion\n")
                    log_fp.flush()
                else:
                    retention(snap_dir, quar_root, job.keep, job.action, log_fp)

                prune_logs(log_dir, args.log_days)
                # Only clear failure state on a fully clean run.
                # If we soft-succeeded (rc 23/24), keep the marker so next run enables --checksum.
                if not soft_succeeded:
                    clear_failure(state_dir, job.device)

                log_fp.write(f"[done] {utc_now().strftime('%F %T')} UTC\n")
                log_fp.flush()

        return 1 if any_failed else 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except Exception as e:
        # No Python traceback in journald — just one useful line.
        print(f"[fatal] {e}", file=sys.stderr)
        raise SystemExit(1)

