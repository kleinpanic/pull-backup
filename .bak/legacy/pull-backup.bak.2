#!/usr/bin/env python3
"""
pull-backup: Pull backups over SSH (WireGuard), snapshot+retention.

Design goals:
- Clear, explicit job state machine with dual-logging (journald + per-job logfile).
- Avoid stalling the whole run when a single endpoint is offline:
  - Preflight reachability check
  - Pass 1: run reachable jobs
  - Defer: unreachable or transient-failing jobs
  - Pass 2: retry deferred jobs near the end
- Robust rsync execution:
  - Optional rsync idle timeout (--timeout)
  - Optional rsync wall-clock cap (--stop-after)
  - Signal-safe process group handling for systemd stop / Ctrl+C
- Resumable snapshots via snapshots/.inprogress-<device>/.run-tag

Exit codes:
- 0: no hard failures (soft-success allowed unless --exit-soft-nonzero)
- 1: at least one hard failure
- 2: only soft-success issues (only if --exit-soft-nonzero)
- 3: fatal environment error (backup filesystem missing/stale, etc.)
- 4: config/usage error

Layout:
  /srv/storage/backups/<class>/<device>/
    snapshots/
      current -> <tag>
      <tag>/...
      .inprogress-<device>/... (left behind if interrupted/failed; reused on resume)
    logs/
      backup-<device>-<tag>.log
  /srv/storage/backups/quarantined/<class>/<device>/<tag>/...
  /var/lib/pull-backup/state/<device>.failure
  /run/pull-backup/lock
"""

from __future__ import annotations

import argparse
import datetime as dt
import errno
import fcntl
import os
import shlex
import shutil
import signal
import subprocess
import sys
import time
from dataclasses import dataclass
from enum import Enum
from pathlib import Path
from typing import Any, Optional, Tuple, Iterable


# ----------------------------
# FS error helpers
# ----------------------------

_FS_BAD_ERRNOS = {errno.ENODEV, errno.ESTALE, errno.EIO}


def _is_bad_fs_error(e: BaseException) -> bool:
    return isinstance(e, OSError) and getattr(e, "errno", None) in _FS_BAD_ERRNOS


def _bad_fs(msg: str) -> RuntimeError:
    return RuntimeError(msg)


def safe_mkdir(path: Path, *, parents: bool = False) -> None:
    """
    mkdir that turns ENODEV/ESTALE/EIO into a clean RuntimeError.
    Also catches the pathlib "exist_ok -> is_dir()" code path which can raise ENODEV.
    """
    try:
        path.mkdir(parents=parents, exist_ok=True)
    except OSError as e:
        if _is_bad_fs_error(e):
            raise _bad_fs(f"backup filesystem not available at {path} (stale mount / missing device)")
        raise
    except Exception as e:
        # Some pathlib internal checks can surface as generic exceptions; re-check stat.
        try:
            _ = os.stat(str(path))
        except OSError as oe:
            if _is_bad_fs_error(oe):
                raise _bad_fs(f"backup filesystem not available at {path} (stale mount / missing device)")
        raise e


def statvfs_free_bytes(path: Path) -> int:
    try:
        st = os.statvfs(str(path))
    except OSError as e:
        if _is_bad_fs_error(e):
            raise _bad_fs(f"backup filesystem not available at {path} (stale mount / missing device)")
        raise
    return st.f_frsize * st.f_bavail


def assert_backups_root_ready(backups_root: Path) -> None:
    try:
        if not backups_root.exists():
            raise RuntimeError(f"backups root does not exist: {backups_root}")
        if not backups_root.is_dir():
            raise RuntimeError(f"backups root is not a directory: {backups_root}")
    except OSError as e:
        if _is_bad_fs_error(e):
            raise _bad_fs(f"backup filesystem not available at {backups_root} (stale mount / missing device)")
        raise
    _ = statvfs_free_bytes(backups_root)  # triggers stale-mount detection


def safe_list_dirs(dirpath: Path) -> list[Path]:
    try:
        return [p for p in dirpath.iterdir() if p.is_dir()]
    except OSError as e:
        if _is_bad_fs_error(e):
            raise _bad_fs(f"backup filesystem not available while listing {dirpath} ({e})")
        raise


def ensure_under(root: Path, p: Path) -> None:
    root = root.resolve()
    p = p.resolve(strict=False)
    try:
        p.relative_to(root)
    except ValueError:
        raise RuntimeError(f"path escapes root: {p} (root={root})")


# ----------------------------
# TOML loading
# ----------------------------

def load_toml(path: Path) -> dict[str, Any]:
    data = path.read_bytes()
    try:
        import tomllib  # py3.11+
        return tomllib.loads(data.decode("utf-8"))
    except Exception:
        try:
            import tomli  # type: ignore
            return tomli.loads(data.decode("utf-8"))
        except Exception as e:
            raise RuntimeError(f"Failed to parse TOML: {path} ({e})")


# ----------------------------
# Time helpers
# ----------------------------

def utc_now() -> dt.datetime:
    return dt.datetime.now(dt.timezone.utc)


def utc_tag() -> str:
    return utc_now().strftime("%Y%m%d-%H%M%SZ")


def iso_wd_and_name() -> Tuple[str, str]:
    now = utc_now()
    return str(now.isoweekday()), now.strftime("%a")  # "1".."7", "Mon"


# ----------------------------
# Schedule matching
# ----------------------------

def when_matches_today(when: str) -> bool:
    when = (when or "").strip().strip('"').strip("'")
    if when == "" or when == "*" or when.lower() == "daily":
        return True
    iso, name = iso_wd_and_name()
    parts = [p.strip() for p in when.split(",") if p.strip()]
    for p in parts:
        if p == iso or p == name or p.lower() == name.lower():
            return True
    return False


# ----------------------------
# State tracking (OFF backup mount)
# ----------------------------

def state_file(state_dir: Path, device: str) -> Path:
    return state_dir / f"{device}.failure"


def has_prior_failure(state_dir: Path, device: str) -> bool:
    f = state_file(state_dir, device)
    try:
        return f.exists()
    except OSError:
        return False


def mark_failure(state_dir: Path, device: str, reason: str) -> None:
    safe_mkdir(state_dir, parents=True)
    f = state_file(state_dir, device)
    count = 0
    if f.exists():
        try:
            for line in f.read_text(encoding="utf-8").splitlines():
                if line.startswith("count="):
                    count = int(line.split("=", 1)[1].strip())
        except Exception:
            count = 0
    count += 1
    f.write_text(
        f"last_time={utc_now().isoformat()}\nreason={reason}\ncount={count}\n",
        encoding="utf-8",
    )


def clear_failure(state_dir: Path, device: str) -> None:
    try:
        state_file(state_dir, device).unlink()
    except FileNotFoundError:
        pass


# ----------------------------
# Retention + log pruning
# ----------------------------

def prune_logs(log_dir: Path, keep_days: int) -> None:
    cutoff = utc_now() - dt.timedelta(days=keep_days)
    try:
        paths = list(log_dir.glob("backup-*.log"))
    except OSError as e:
        if _is_bad_fs_error(e):
            return
        raise
    for p in paths:
        try:
            mtime = dt.datetime.fromtimestamp(p.stat().st_mtime, tz=dt.timezone.utc)
            if mtime < cutoff:
                p.unlink()
        except Exception:
            pass


def retention(snap_dir: Path, quar_root: Path, keep: int, action: str, log) -> None:
    snaps = sorted([p for p in safe_list_dirs(snap_dir) if p.name.startswith("20")])
    if len(snaps) <= keep:
        return
    old = snaps[: len(snaps) - keep]
    log.state("RETENTION_SCAN", f"found {len(old)} snapshots older than keep={keep}")

    if action == "keep":
        log.state("RETENTION", "action=keep (leaving older snapshots)")
        return

    if action == "quarantine":
        safe_mkdir(quar_root, parents=True)
        for d in old:
            dst = quar_root / d.name
            log.state("RETENTION", f"quarantine {d.name} -> {dst}")
            d.rename(dst)
        return

    if action == "delete":
        for d in old:
            log.state("RETENTION", f"delete {d.name}")
            shutil.rmtree(d)
        return

    raise RuntimeError(f"unknown retention action: {action}")


# ----------------------------
# SSH helpers
# ----------------------------

def ssh_cmd_base(ssh_config: Optional[Path]) -> list[str]:
    base = [
        "ssh",
        "-o", "BatchMode=yes",
        "-o", "ConnectTimeout=8",
        "-o", "ServerAliveInterval=5",
        "-o", "ServerAliveCountMax=2",
    ]
    if ssh_config and ssh_config.exists():
        base += ["-F", str(ssh_config)]
    return base


def run_quick(cmd: list[str], *, timeout_s: int = 15) -> tuple[int, str]:
    try:
        p = subprocess.run(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=timeout_s,
        )
        return p.returncode, (p.stdout or "")
    except subprocess.TimeoutExpired as e:
        out = ""
        if e.stdout:
            out = str(e.stdout)
        return 124, out + ("\n[local] ssh probe timed out\n")


def ssh_probe(host: str, ssh_config: Optional[Path], *, timeout_s: int = 15) -> tuple[bool, str]:
    cmd = ssh_cmd_base(ssh_config) + [host, "true"]
    rc, out = run_quick(cmd, timeout_s=timeout_s)
    return (rc == 0), out


# ----------------------------
# Resumable run tag
# ----------------------------

def load_or_create_run_tag(inprog: Path) -> tuple[str, bool]:
    tag_file = inprog / ".run-tag"
    if tag_file.exists():
        tag = tag_file.read_text(encoding="utf-8").strip()
        if tag:
            return tag, True

    tag = utc_tag()
    safe_mkdir(inprog, parents=True)
    tag_file.write_text(tag + "\n", encoding="utf-8")
    return tag, False


def clear_run_tag_in_tree(tree: Path) -> None:
    try:
        (tree / ".run-tag").unlink(missing_ok=True)
    except Exception:
        pass


# ----------------------------
# Dual logger
# ----------------------------

class DualLogger:
    """
    Writes key state transitions to:
      - stdout (journald)
      - a per-job logfile
    Also supports writing raw rsync output through the same tee path.
    """

    def __init__(self, *, job: str, log_fp):
        self.job = job
        self.fp = log_fp

    def _emit(self, line: str) -> None:
        # Ensure single-line journald friendly output.
        if not line.endswith("\n"):
            line += "\n"
        sys.stdout.write(line)
        sys.stdout.flush()
        self.fp.write(line)
        self.fp.flush()

    def state(self, state: str, msg: str) -> None:
        ts = utc_now().strftime("%F %T")
        self._emit(f"[{ts} UTC] [{self.job}] {state}: {msg}")

    def raw(self, text: str) -> None:
        # For rsync output: emit as-is (but ensure newline).
        if text == "":
            return
        if not text.endswith("\n"):
            text += "\n"
        sys.stdout.write(text)
        sys.stdout.flush()
        self.fp.write(text)
        self.fp.flush()


# ----------------------------
# Signal-safe runner (process group)
# ----------------------------

class _Runner:
    def __init__(self) -> None:
        self.child_pgid: Optional[int] = None
        self.signal_seen: Optional[int] = None


RUNNER = _Runner()


def _forward_signal(sig: int, _frame) -> None:
    RUNNER.signal_seen = sig
    if RUNNER.child_pgid is not None:
        try:
            os.killpg(RUNNER.child_pgid, sig)
        except ProcessLookupError:
            pass


def _kill_pgrp(pgid: int, sig: int) -> None:
    try:
        os.killpg(pgid, sig)
    except ProcessLookupError:
        pass


def run_and_tee(
    cmd: list[str],
    log: DualLogger,
    *,
    kill_grace_s: int = 20,
    wallclock_timeout_s: int = 0,
) -> tuple[int, Optional[int], str]:
    """
    Runs cmd, tees stdout+stderr into DualLogger.
    Returns: (rc, signal_seen, reason)
      - reason is a short internal string for summaries.
    """
    import selectors

    old_int = signal.getsignal(signal.SIGINT)
    old_term = signal.getsignal(signal.SIGTERM)
    signal.signal(signal.SIGINT, _forward_signal)
    signal.signal(signal.SIGTERM, _forward_signal)

    start = time.time()
    reason = "unknown"
    rc = 1
    sig_seen: Optional[int] = None

    try:
        p = subprocess.Popen(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            bufsize=1,
            start_new_session=True,  # new process group
        )
        assert p.stdout is not None
        RUNNER.child_pgid = os.getpgid(p.pid)
        RUNNER.signal_seen = None

        sel = selectors.DefaultSelector()
        sel.register(p.stdout, selectors.EVENT_READ)

        # Stream output without blocking forever, enforce wall clock timeout if requested.
        while True:
            # Exit if process ended and no more output
            if p.poll() is not None:
                # Drain remaining output if any
                try:
                    rest = p.stdout.read()
                    if rest:
                        log.raw(rest)
                except Exception:
                    pass
                break

            if wallclock_timeout_s > 0 and (time.time() - start) > wallclock_timeout_s:
                reason = "wallclock_timeout"
                log.state("RUN_TIMEOUT", f"wallclock timeout exceeded ({wallclock_timeout_s}s); terminating rsync")
                _kill_pgrp(RUNNER.child_pgid, signal.SIGTERM)
                t0 = time.time()
                while time.time() - t0 < kill_grace_s:
                    if p.poll() is not None:
                        break
                    time.sleep(0.2)
                if p.poll() is None:
                    log.state("RUN_TIMEOUT", "rsync did not exit after SIGTERM; sending SIGKILL")
                    _kill_pgrp(RUNNER.child_pgid, signal.SIGKILL)
                break

            events = sel.select(timeout=0.5)
            if not events:
                continue

            for key, _mask in events:
                try:
                    chunk = key.fileobj.readline()
                except Exception:
                    chunk = ""
                if chunk:
                    # Avoid CR-only progress spam: keep it readable in logs.
                    chunk = chunk.replace("\r", "\n")
                    log.raw(chunk)

        rc = p.wait()
        sig_seen = RUNNER.signal_seen
        if sig_seen is not None:
            reason = f"signal_{sig_seen}"
        elif reason == "wallclock_timeout":
            # Map to a conventional timeout-ish code if rsync didn't provide a useful one.
            if rc == 0:
                rc = 124
        else:
            reason = "exit"

        return rc, sig_seen, reason

    finally:
        # Cleanup any still-running child group
        if RUNNER.child_pgid is not None:
            try:
                os.killpg(RUNNER.child_pgid, 0)
            except ProcessLookupError:
                pass
            else:
                _kill_pgrp(RUNNER.child_pgid, signal.SIGTERM)
                t0 = time.time()
                while time.time() - t0 < kill_grace_s:
                    try:
                        os.killpg(RUNNER.child_pgid, 0)
                    except ProcessLookupError:
                        break
                    time.sleep(0.2)
                else:
                    _kill_pgrp(RUNNER.child_pgid, signal.SIGKILL)

        RUNNER.child_pgid = None
        RUNNER.signal_seen = None
        signal.signal(signal.SIGINT, old_int)
        signal.signal(signal.SIGTERM, old_term)


# ----------------------------
# Load-shedding
# ----------------------------

def wait_for_load(max_load: float, log: DualLogger, poll_s: int = 10) -> None:
    if max_load <= 0:
        return
    warned = False
    while True:
        try:
            one, _five, _fifteen = os.getloadavg()
        except OSError:
            return
        if one <= max_load:
            return
        if not warned:
            log.state("LOAD_WAIT", f"loadavg(1m)={one:.2f} > max_load={max_load:.2f}; waiting")
            warned = True
        time.sleep(max(1, poll_s))


# ----------------------------
# Jobs config
# ----------------------------

@dataclass(frozen=True)
class Job:
    device: str
    ssh: str
    path: str
    when: str
    description: str
    klass: str
    keep: int
    action: str


def parse_jobs(cfg: dict[str, Any], defaults: dict[str, Any]) -> list[Job]:
    jobs_raw = cfg.get("job", [])
    if not isinstance(jobs_raw, list):
        raise RuntimeError("jobs.toml must contain one or more [[job]] tables")
    out: list[Job] = []
    for j in jobs_raw:
        if not isinstance(j, dict):
            continue
        device = str(j.get("device", "")).strip()
        if not device:
            continue
        sshv = str(j.get("ssh", device)).strip()
        path = str(j.get("path", f"/home/{device}/")).strip()
        if not path.endswith("/"):
            path += "/"
        when = str(j.get("when", "daily")).strip()
        desc = str(j.get("description", "")).strip()
        klass = str(j.get("class", defaults["class"])).strip()
        keep = int(j.get("keep", defaults["keep"]))
        if keep < 1:
            keep = 1
        action = str(j.get("action", defaults["action"])).strip()
        out.append(Job(device, sshv, path, when, desc, klass, keep, action))
    return out


# ----------------------------
# Job outcome + summary
# ----------------------------

class Outcome(Enum):
    SUCCESS = "success"
    SOFT_SUCCESS = "soft_success"
    FAILED = "failed"
    SKIPPED = "skipped"
    DEFERRED = "deferred"


@dataclass
class JobSummary:
    job: Job
    outcome: Outcome
    reason: str
    tag: Optional[str]
    started: Optional[dt.datetime]
    ended: Optional[dt.datetime]
    attempts: int


def _fmt_dur(s: JobSummary) -> str:
    if not s.started or not s.ended:
        return "-"
    sec = (s.ended - s.started).total_seconds()
    if sec < 0:
        return "-"
    if sec < 60:
        return f"{int(sec)}s"
    if sec < 3600:
        return f"{int(sec//60)}m{int(sec%60)}s"
    return f"{int(sec//3600)}h{int((sec%3600)//60)}m"


# ----------------------------
# Main per-job runner
# ----------------------------

def run_one_job(
    job: Job,
    *,
    backups_root: Path,
    state_dir: Path,
    ssh_config: Optional[Path],
    args,
) -> JobSummary:
    started = utc_now()

    dev_dir = backups_root / job.klass / job.device
    snap_dir = dev_dir / "snapshots"
    log_dir = dev_dir / "logs"
    inprog = snap_dir / f".inprogress-{job.device}"
    quar_root = backups_root / "quarantined" / job.klass / job.device

    for p in (dev_dir, snap_dir, log_dir, inprog, quar_root):
        ensure_under(backups_root, p)

    safe_mkdir(log_dir, parents=True)
    safe_mkdir(snap_dir, parents=True)

    tag, resumed = load_or_create_run_tag(inprog)
    log_file = log_dir / f"backup-{job.device}-{tag}.log"

    attempts = 0

    with open(log_file, "a" if log_file.exists() else "w", encoding="utf-8") as log_fp:
        log = DualLogger(job=job.device, log_fp=log_fp)
        src = f"{job.ssh}:{job.path}"

        log.state("JOB_START", f"{'resume' if resumed else 'start'} tag={tag} class={job.klass} src={src}")
        if job.description:
            log.state("JOB_INFO", f"description={job.description}")

        # Decide deep verify if requested or prior failure marker exists.
        deep = bool(args.deep_verify or has_prior_failure(state_dir, job.device))

        # link-dest from newest completed snapshot
        snaps = sorted([p for p in safe_list_dirs(snap_dir) if p.name.startswith("20")])
        last_snap = snaps[-1] if snaps else None

        # Build rsync args (daemon-friendly output; no progress2)
        rsync_opts = [
            "-aHAXx",
            "--numeric-ids",
            "--partial",
            "--partial-dir=.rsync-partial",
            "--info=stats2,name0",   # readable in logs
            "--human-readable",
        ]
        if not args.no_compress:
            rsync_opts.append("--compress")

        if args.rsync_timeout and args.rsync_timeout > 0:
            rsync_opts.append(f"--timeout={args.rsync_timeout}")

        if args.rsync_stop_after_mins and args.rsync_stop_after_mins > 0:
            rsync_opts.append(f"--stop-after={args.rsync_stop_after_mins}")

        if args.bwlimit and args.bwlimit > 0:
            rsync_opts.append(f"--bwlimit={args.bwlimit}")

        if deep:
            rsync_opts.append("--checksum")
            log.state("JOB_MODE", "deep-verify enabled (--checksum) due to prior failure or flag")

        if last_snap:
            rsync_opts.append(f"--link-dest={last_snap}")

        safe_mkdir(inprog, parents=True)

        ssh_str = "ssh -o BatchMode=yes -o ConnectTimeout=8 -o ServerAliveInterval=5 -o ServerAliveCountMax=2"
        if ssh_config and ssh_config.exists():
            ssh_str += f" -F {shlex.quote(str(ssh_config))}"

        cmd = ["rsync"] + rsync_opts + ["-e", ssh_str, src, str(inprog) + "/"]

        # Soft-success handling
        soft_success_rcs = set() if args.strict_rsync else {23, 24}

        # Transient rsync exit codes:
        # 12 protocol stream, 30 timeout send/receive, 35 daemon timeout, 255 remote-shell failure.
        transient_rcs = {12, 30, 35, 255}

        # Attempt loop
        while attempts < max(1, args.attempts):
            attempts += 1

            wait_for_load(args.max_load, log, poll_s=max(1, args.load_poll))

            log.state("RUN_PRECHECK", f"attempt={attempts}: probing ssh reachability")
            ok, out = ssh_probe(job.ssh, ssh_config, timeout_s=args.ssh_probe_timeout)
            if out.strip():
                # Only dump probe output if there is any.
                for line in out.splitlines():
                    log.raw(f"[ssh-probe] {line}")

            if not ok:
                # Don't stall here: treat as "defer" rather than waiting long.
                log.state("RUN_DEFER", f"ssh not reachable (attempt={attempts}); will defer/skip further attempts in this pass")
                mark_failure(state_dir, job.device, "ssh_unreachable")
                ended = utc_now()
                return JobSummary(job, Outcome.DEFERRED, "ssh_unreachable", tag, started, ended, attempts)

            log.state("RUN_START", f"attempt={attempts}: running rsync (cmd logged below)")
            log.raw("[cmd] " + " ".join(shlex.quote(c) for c in cmd))

            wall_s = int(args.wallclock_timeout_s) if args.wallclock_timeout_s else 0
            rc, sig_seen, why = run_and_tee(cmd, log, kill_grace_s=args.kill_grace_s, wallclock_timeout_s=wall_s)

            if sig_seen is not None or rc == 20:
                log.state("RUN_INTERRUPTED", f"signal={sig_seen} rc={rc}; leaving partials for resume in {inprog}")
                mark_failure(state_dir, job.device, "interrupted")
                prune_logs(log_dir, args.log_days)
                ended = utc_now()
                return JobSummary(job, Outcome.FAILED, "interrupted", tag, started, ended, attempts)

            if rc == 0:
                log.state("RUN_OK", f"rsync rc=0 ({why})")
                break

            if rc in soft_success_rcs:
                log.state("RUN_SOFT", f"rsync rc={rc} treated as SOFT_SUCCESS; snapshot will be finalized (may be incomplete)")
                mark_failure(state_dir, job.device, f"soft_rsync_rc_{rc}")
                # finalize anyway
                break

            if rc in transient_rcs:
                log.state("RUN_RETRY", f"transient rsync rc={rc}; retrying ({attempts}/{args.attempts})")
                mark_failure(state_dir, job.device, f"transient_rsync_rc_{rc}")
                if args.retry_sleep > 0:
                    time.sleep(args.retry_sleep)
                continue

            # Non-transient hard failure: stop attempts.
            log.state("RUN_FAIL", f"non-transient rsync rc={rc}; leaving partials in {inprog}")
            mark_failure(state_dir, job.device, f"rsync_rc_{rc}")
            prune_logs(log_dir, args.log_days)
            ended = utc_now()
            return JobSummary(job, Outcome.FAILED, f"rsync_rc_{rc}", tag, started, ended, attempts)

        # If we exhausted attempts and still not rc==0/soft, treat as deferred (so pass 2 can retry later)
        # The loop breaks only on rc==0 or soft-success; otherwise, it returns earlier or continues.
        # If we get here, it means rc==0 OR soft-success.
        soft = has_prior_failure(state_dir, job.device) and (state_file(state_dir, job.device).read_text(encoding="utf-8").find("soft_rsync_rc_") >= 0)

        # Finalize snapshot
        final = snap_dir / tag
        if final.exists():
            shutil.rmtree(final)

        log.state("FINALIZE", f"renaming in-progress -> final: {inprog} -> {final}")
        inprog.rename(final)
        clear_run_tag_in_tree(final)

        cur = snap_dir / "current"
        try:
            if cur.is_symlink() or cur.exists():
                cur.unlink()
        except FileNotFoundError:
            pass
        cur.symlink_to(final)
        log.state("FINALIZE", f"updated current -> {final}")

        # retention
        if job.action == "delete" and not args.auto:
            log.state("RETENTION", "action=delete but --auto not set; skipping deletion")
        else:
            retention(snap_dir, quar_root, job.keep, job.action, log)

        prune_logs(log_dir, args.log_days)

        # Clear failure marker only on fully clean success.
        # If we soft-succeeded, keep marker so next run can deep-verify.
        outcome = Outcome.SUCCESS
        reason = "success"
        if soft:
            outcome = Outcome.SOFT_SUCCESS
            reason = "soft_success"
        else:
            clear_failure(state_dir, job.device)

        log.state("JOB_DONE", f"outcome={outcome.value} attempts={attempts}")
        ended = utc_now()
        return JobSummary(job, outcome, reason, tag, started, ended, attempts)


# ----------------------------
# Main
# ----------------------------

def main() -> int:
    ap = argparse.ArgumentParser(description="Pull backups over SSH (WireGuard), snapshot+retention.")
    ap.add_argument("--daemon", action="store_true", help="run scheduled jobs from jobs.toml")
    ap.add_argument("--jobs-file", default="/etc/pull-backup/jobs.toml")
    ap.add_argument("--backups-root", default="/srv/storage/backups")
    ap.add_argument("--state-dir", default="/var/lib/pull-backup/state")
    ap.add_argument("--class", dest="klass", default="laptops")
    ap.add_argument("--keep", type=int, default=3)
    ap.add_argument("--action", choices=["quarantine", "delete", "keep"], default="quarantine")
    ap.add_argument("--log-days", type=int, default=30)
    ap.add_argument("--auto", action="store_true", help="allow destructive actions like retention delete")
    ap.add_argument("--deep-verify", action="store_true", help="force rsync --checksum")
    ap.add_argument("--ssh-config", default="/root/.ssh/config")
    ap.add_argument("--lock-file", default="/run/pull-backup/lock")

    # Retry / robustness knobs
    ap.add_argument("--attempts", type=int, default=2, help="max attempts per job in a single pass on transient rsync errors")
    ap.add_argument("--retry-sleep", type=int, default=10, help="seconds to sleep between transient rsync retries")
    ap.add_argument("--passes", type=int, default=2, help="how many passes: pass 1 runs reachable; pass 2 retries deferred")
    ap.add_argument("--pass-delay", type=int, default=120, help="seconds to wait between passes before retrying deferred")

    # SSH probe behavior (preflight + per-job reachability checks)
    ap.add_argument("--ssh-probe-timeout", type=int, default=12, help="timeout (seconds) for ssh reachability probe")

    # Rsync knobs
    ap.add_argument("--rsync-timeout", type=int, default=120, help="rsync --timeout seconds (idle I/O timeout; 0 disables)")
    ap.add_argument("--rsync-stop-after-mins", type=int, default=0, help="rsync --stop-after minutes (wall-clock cap; 0 disables)")
    ap.add_argument("--bwlimit", type=int, default=0, help="rsync --bwlimit KB/s (0 disables)")
    ap.add_argument("--no-compress", action="store_true", help="disable rsync compression to reduce CPU")
    ap.add_argument("--strict-rsync", action="store_true", help="treat rsync exit codes 23/24 as hard failures (default: finalize as soft-success)")

    # Extra wall-clock guard (Python side)
    ap.add_argument("--wallclock-timeout-s", type=int, default=0, help="hard kill rsync if it runs longer than this many seconds (0 disables)")
    ap.add_argument("--kill-grace-s", type=int, default=20, help="seconds to wait after SIGTERM before SIGKILL")

    # Load shedding
    ap.add_argument("--max-load", type=float, default=4.0, help="wait until 1m loadavg <= this before starting rsync (0 disables)")
    ap.add_argument("--load-poll", type=int, default=10, help="seconds between loadavg checks")

    # Exit behavior
    ap.add_argument("--exit-soft-nonzero", action="store_true", help="exit 2 if there were soft-success jobs (even if no hard failures)")

    args = ap.parse_args()
    os.umask(0o077)

    backups_root = Path(args.backups_root).resolve()
    if str(backups_root) != "/srv/storage/backups":
        raise RuntimeError("backups-root must be exactly /srv/storage/backups")

    if not args.daemon:
        raise RuntimeError("Use --daemon (this tool is scheduler-driven).")

    # Locking (off-mount)
    lock_path = Path(args.lock_file)
    safe_mkdir(lock_path.parent, parents=True)

    with open(lock_path, "w") as lock_fp:
        fcntl.flock(lock_fp, fcntl.LOCK_EX)

        # Verify backup fs is usable
        assert_backups_root_ready(backups_root)

        state_dir = Path(args.state_dir)
        cfg_path = Path(args.jobs_file)
        defaults = {"class": args.klass, "keep": args.keep, "action": args.action}

        cfg = load_toml(cfg_path)
        jobs_all = parse_jobs(cfg, defaults)

        # Scheduled selection
        jobs = []
        for j in jobs_all:
            if when_matches_today(j.when):
                jobs.append(j)
            else:
                ts = utc_now().strftime("%F %T")
                print(f"[{ts} UTC] [daemon] skip {j.device} (when={j.when})")

        if not jobs:
            ts = utc_now().strftime("%F %T")
            print(f"[{ts} UTC] [daemon] no jobs to run today")
            return 0

        ssh_config = Path(args.ssh_config) if args.ssh_config else None

        # Preflight reachability scan (fast)
        ts = utc_now().strftime("%F %T")
        print(f"[{ts} UTC] [run] PREFLIGHT: probing {len(jobs)} endpoints")
        reachable: list[Job] = []
        unreachable: list[tuple[Job, str]] = []
        for j in jobs:
            ok, out = ssh_probe(j.ssh, ssh_config, timeout_s=args.ssh_probe_timeout)
            if ok:
                reachable.append(j)
            else:
                reason = "ssh_unreachable"
                if out.strip():
                    reason = "ssh_unreachable_with_output"
                unreachable.append((j, reason))

        ts = utc_now().strftime("%F %T")
        print(f"[{ts} UTC] [run] PREFLIGHT: reachable={len(reachable)} unreachable={len(unreachable)}")
        for j, r in unreachable:
            print(f"[{ts} UTC] [run] PREFLIGHT_DEFER: {j.device} ({j.ssh}) reason={r}")

        summaries: list[JobSummary] = []
        deferred: list[Job] = [j for (j, _r) in unreachable]

        # Pass loop
        passes = max(1, int(args.passes))
        for pidx in range(passes):
            pass_no = pidx + 1
            ts = utc_now().strftime("%F %T")
            print(f"[{ts} UTC] [run] PASS_START: {pass_no}/{passes}")

            if pass_no == 1:
                run_list = reachable
            else:
                # retry only deferred
                run_list = deferred

            if not run_list:
                print(f"[{ts} UTC] [run] PASS_EMPTY: nothing to run in pass {pass_no}")
            else:
                next_deferred: list[Job] = []
                for job in run_list:
                    s = run_one_job(
                        job,
                        backups_root=backups_root,
                        state_dir=state_dir,
                        ssh_config=ssh_config,
                        args=args,
                    )
                    summaries.append(s)

                    if s.outcome == Outcome.DEFERRED:
                        # Only retry deferred if we have more passes remaining.
                        if pass_no < passes:
                            next_deferred.append(job)

                deferred = next_deferred

            ts = utc_now().strftime("%F %T")
            print(f"[{ts} UTC] [run] PASS_END: {pass_no}/{passes} deferred_for_next_pass={len(deferred)}")

            if pass_no < passes and args.pass_delay > 0 and deferred:
                print(f"[{ts} UTC] [run] PASS_SLEEP: sleeping {args.pass_delay}s before next pass")
                time.sleep(args.pass_delay)

        # Summarize results
        hard_fail = any(s.outcome == Outcome.FAILED for s in summaries)
        soft = any(s.outcome == Outcome.SOFT_SUCCESS for s in summaries)
        deferred_left = len(deferred)

        ts = utc_now().strftime("%F %T")
        print(f"[{ts} UTC] [summary] ------------------------------")
        # Group by outcome
        for outc in (Outcome.SUCCESS, Outcome.SOFT_SUCCESS, Outcome.FAILED, Outcome.DEFERRED, Outcome.SKIPPED):
            grp = [s for s in summaries if s.outcome == outc]
            if not grp:
                continue
            print(f"[{ts} UTC] [summary] {outc.value}: {len(grp)}")
            for s in grp:
                tag_part = f" tag={s.tag}" if s.tag else ""
                print(
                    f"[{ts} UTC] [summary]  - {s.job.device}: reason={s.reason}{tag_part} "
                    f"attempts={s.attempts} dur={_fmt_dur(s)}"
                )

        if deferred_left > 0:
            print(f"[{ts} UTC] [summary] deferred_unfinished: {deferred_left}")
            for j in deferred:
                print(f"[{ts} UTC] [summary]  - {j.device}: still deferred after all passes")

        print(f"[{ts} UTC] [summary] ------------------------------")

        if hard_fail:
            return 1
        if soft and args.exit_soft_nonzero:
            return 2
        return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except RuntimeError as e:
        # Clean error line in journald (no Python traceback)
        print(f"[fatal] {e}", file=sys.stderr)
        # Distinguish "environment is broken" from job failures
        msg = str(e).lower()
        if "backup filesystem not available" in msg or "stale mount" in msg:
            raise SystemExit(3)
        raise SystemExit(4)
    except Exception as e:
        print(f"[fatal] {e}", file=sys.stderr)
        raise SystemExit(1)

