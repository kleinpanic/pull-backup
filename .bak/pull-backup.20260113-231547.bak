#!/usr/bin/env python3
"""
pull-backup: Pull backups over SSH (WireGuard), snapshot+retention.

Key behaviors (preserved):
- Preflight reachability = ssh works AND remote has rsync.
- Resumable snapshots via snapshots/.inprogress-<device>/.run-tag
- Dual logging:
  - stdout (journald via systemd)
  - per-job logfile under .../<class>/<device>/logs/
- Retention: keep N snapshots per job (default 3).
- Progress: periodic bytes-so-far + rate using du on the inprogress dir (no rsync --progress).
- “No timeout if data is moving”:
  - rsync --timeout defaults to 0 (disabled)
  - optional stall watchdog: kill rsync only if dest bytes haven’t increased for --stall-timeout-s

Behavior improvements:
1) Retention destination renamed:
   - Old "quarantined/" directory becomes "legacy/" (more obvious).
   - action=quarantine remains accepted (back-compat) but writes into legacy/.

2) Off-days do useful work:
   - If no jobs match today's schedule, we still try to resume any jobs with
     snapshots/.inprogress-<device> payload/tag present, even if schedule doesn't match.

3) Better preflight ordering:
   - Resumables first, then prior failures, then oldest last snapshot, then fewer snapshots.
   - Reachability is re-evaluated per pass so ordering stays dynamic.

4) Optional idle archiving:
   - When there are no scheduled jobs AND no resumables (i.e., truly idle),
     compress legacy snapshots into archives/<class>/<device>/<tag>.tar.zst using zstd -12.
   - Conservative defaults: at most 1 archive per idle run, and max bytes budget.

Exit codes:
- 0: no hard failures (soft-success allowed unless --exit-soft-nonzero)
- 1: at least one hard failure
- 2: only soft-success issues (only if --exit-soft-nonzero)
- 3: fatal environment error (backup filesystem missing/stale, etc.)
- 4: config/usage error
"""

from __future__ import annotations

import argparse
import datetime as dt
import errno
import fcntl
import math
import os
import shlex
import shutil
import signal
import subprocess
import sys
import time
from dataclasses import dataclass
from enum import Enum
from pathlib import Path
from typing import Any, Optional, Tuple


# ----------------------------
# FS error helpers
# ----------------------------

_FS_BAD_ERRNOS = {errno.ENODEV, errno.ESTALE, errno.EIO}


def _is_bad_fs_error(e: BaseException) -> bool:
    return isinstance(e, OSError) and getattr(e, "errno", None) in _FS_BAD_ERRNOS


def _bad_fs(msg: str) -> RuntimeError:
    return RuntimeError(msg)


def safe_mkdir(path: Path, *, parents: bool = False) -> None:
    try:
        path.mkdir(parents=parents, exist_ok=True)
    except OSError as e:
        if _is_bad_fs_error(e):
            raise _bad_fs(f"backup filesystem not available at {path} (stale mount / missing device)")
        raise
    except Exception as e:
        try:
            _ = os.stat(str(path))
        except OSError as oe:
            if _is_bad_fs_error(oe):
                raise _bad_fs(f"backup filesystem not available at {path} (stale mount / missing device)")
        raise e


def statvfs_free_bytes(path: Path) -> int:
    try:
        st = os.statvfs(str(path))
    except OSError as e:
        if _is_bad_fs_error(e):
            raise _bad_fs(f"backup filesystem not available at {path} (stale mount / missing device)")
        raise
    return st.f_frsize * st.f_bavail


def assert_backups_root_ready(backups_root: Path) -> None:
    try:
        if not backups_root.exists():
            raise RuntimeError(f"backups root does not exist: {backups_root}")
        if not backups_root.is_dir():
            raise RuntimeError(f"backups root is not a directory: {backups_root}")
    except OSError as e:
        if _is_bad_fs_error(e):
            raise _bad_fs(f"backup filesystem not available at {backups_root} (stale mount / missing device)")
        raise
    _ = statvfs_free_bytes(backups_root)


def safe_list_dirs(dirpath: Path) -> list[Path]:
    try:
        return [p for p in dirpath.iterdir() if p.is_dir()]
    except OSError as e:
        if _is_bad_fs_error(e):
            raise _bad_fs(f"backup filesystem not available while listing {dirpath} ({e})")
        raise


def ensure_under(root: Path, p: Path) -> None:
    root = root.resolve()
    p = p.resolve(strict=False)
    try:
        p.relative_to(root)
    except ValueError:
        raise RuntimeError(f"path escapes root: {p} (root={root})")


# ----------------------------
# TOML loading
# ----------------------------

def load_toml(path: Path) -> dict[str, Any]:
    data = path.read_bytes()
    try:
        import tomllib  # py3.11+
        return tomllib.loads(data.decode("utf-8"))
    except Exception:
        try:
            import tomli  # type: ignore
            return tomli.loads(data.decode("utf-8"))
        except Exception as e:
            raise RuntimeError(f"Failed to parse TOML: {path} ({e})")


# ----------------------------
# Time helpers
# ----------------------------

def now_local() -> dt.datetime:
    return dt.datetime.now().astimezone()


def utc_now() -> dt.datetime:
    return dt.datetime.now(dt.timezone.utc)


def utc_tag() -> str:
    return utc_now().strftime("%Y%m%d-%H%M%SZ")


def iso_wd_and_name_local() -> Tuple[str, str]:
    n = now_local()
    return str(n.isoweekday()), n.strftime("%a")


def parse_utc_tag(s: str) -> Optional[dt.datetime]:
    """
    Parse snapshot tag directory names of form YYYYmmdd-HHMMSSZ (UTC).
    Returns UTC datetime or None.
    """
    try:
        return dt.datetime.strptime(s, "%Y%m%d-%H%M%SZ").replace(tzinfo=dt.timezone.utc)
    except Exception:
        return None


# ----------------------------
# Schedule matching
# ----------------------------

def when_matches_today(when: str) -> bool:
    when = (when or "").strip().strip('"').strip("'")
    if when == "" or when == "*" or when.lower() == "daily":
        return True
    iso, name = iso_wd_and_name_local()
    parts = [p.strip() for p in when.split(",") if p.strip()]
    for p in parts:
        if p == iso or p.lower() == name.lower():
            return True
    return False


# ----------------------------
# State tracking (OFF backup mount)
# ----------------------------

def state_file(state_dir: Path, device: str) -> Path:
    return state_dir / f"{device}.failure"


def has_prior_failure(state_dir: Path, device: str) -> bool:
    f = state_file(state_dir, device)
    try:
        return f.exists()
    except OSError:
        return False


def mark_failure(state_dir: Path, device: str, reason: str) -> None:
    safe_mkdir(state_dir, parents=True)
    f = state_file(state_dir, device)
    count = 0
    if f.exists():
        try:
            for line in f.read_text(encoding="utf-8").splitlines():
                if line.startswith("count="):
                    count = int(line.split("=", 1)[1].strip())
        except Exception:
            count = 0
    count += 1
    f.write_text(
        f"last_time={utc_now().isoformat()}\nreason={reason}\ncount={count}\n",
        encoding="utf-8",
    )


def clear_failure(state_dir: Path, device: str) -> None:
    try:
        state_file(state_dir, device).unlink()
    except FileNotFoundError:
        pass


def read_failures_summary(state_dir: Path) -> list[tuple[str, str, str, str]]:
    """
    Returns list of (device, last_time, reason, count).
    Best-effort; safe if files missing/partial.
    """
    out: list[tuple[str, str, str, str]] = []
    try:
        if not state_dir.exists():
            return out
        for p in sorted(state_dir.glob("*.failure")):
            dev = p.stem
            last_time = "-"
            reason = "-"
            count = "-"
            try:
                for line in p.read_text(encoding="utf-8").splitlines():
                    if line.startswith("last_time="):
                        last_time = line.split("=", 1)[1].strip()
                    elif line.startswith("reason="):
                        reason = line.split("=", 1)[1].strip()
                    elif line.startswith("count="):
                        count = line.split("=", 1)[1].strip()
            except Exception:
                pass
            out.append((dev, last_time, reason, count))
    except Exception:
        return out
    return out


# ----------------------------
# Retention + log pruning
# ----------------------------

def prune_logs(log_dir: Path, keep_days: int) -> None:
    cutoff = utc_now() - dt.timedelta(days=keep_days)
    try:
        paths = list(log_dir.glob("backup-*.log"))
    except OSError as e:
        if _is_bad_fs_error(e):
            return
        raise
    for p in paths:
        try:
            mtime = dt.datetime.fromtimestamp(p.stat().st_mtime, tz=dt.timezone.utc)
            if mtime < cutoff:
                p.unlink()
        except Exception:
            pass


def retention(snap_dir: Path, legacy_root: Path, keep: int, action: str, log) -> None:
    snaps = sorted([p for p in safe_list_dirs(snap_dir) if p.name.startswith("20")])
    if len(snaps) <= keep:
        return
    old = snaps[: len(snaps) - keep]
    log.state("RETENTION_SCAN", f"found {len(old)} snapshots older than keep={keep}")

    act = (action or "").strip().lower()
    # Back-compat: "quarantine" now means "legacy"
    if act == "quarantine":
        act = "legacy"

    if act == "keep":
        log.state("RETENTION", "action=keep (leaving older snapshots)")
        return

    if act == "legacy":
        safe_mkdir(legacy_root, parents=True)
        for d in old:
            dst = legacy_root / d.name
            log.state("RETENTION", f"legacy {d.name} -> {dst}")
            d.rename(dst)
        return

    if act == "delete":
        for d in old:
            log.state("RETENTION", f"delete {d.name}")
            shutil.rmtree(d)
        return

    raise RuntimeError(f"unknown retention action: {action}")


# ----------------------------
# SSH helpers (reachability = rsync-ready)
# ----------------------------

def ssh_cmd_base(ssh_config: Optional[Path]) -> list[str]:
    base = [
        "ssh",
        "-o", "BatchMode=yes",
        "-o", "ConnectTimeout=8",
        "-o", "ServerAliveInterval=5",
        "-o", "ServerAliveCountMax=2",
    ]
    if ssh_config and ssh_config.exists():
        base += ["-F", str(ssh_config)]
    return base


def run_quick(cmd: list[str], *, timeout_s: int = 15) -> tuple[int, str]:
    try:
        p = subprocess.run(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=timeout_s,
        )
        return p.returncode, (p.stdout or "")
    except subprocess.TimeoutExpired as e:
        out = ""
        if e.stdout:
            out = str(e.stdout)
        return 124, out + ("\n[local] probe timed out\n")


def rsync_ready_probe(host: str, ssh_config: Optional[Path], *, timeout_s: int = 15) -> tuple[bool, str]:
    cmd = ssh_cmd_base(ssh_config) + [host, "command -v rsync >/dev/null 2>&1 && echo RSYNC_OK"]
    rc, out = run_quick(cmd, timeout_s=timeout_s)
    ok = (rc == 0) and ("RSYNC_OK" in out)
    return ok, out


# ----------------------------
# Resumable run tag + detection
# ----------------------------

def _inprogress_payload_present(inprog: Path) -> bool:
    """
    True if this in-progress dir looks like it has "real" payload (not just tag/partials dir).
    Used to detect resumable work without mutating anything.
    """
    try:
        if not inprog.exists() or not inprog.is_dir():
            return False
        allowed = {".run-tag", ".rsync-partial"}
        for p in inprog.iterdir():
            if p.name in allowed:
                continue
            return True
        return False
    except Exception:
        return False


def has_resumable_inprogress(snap_dir: Path, device: str) -> tuple[bool, Optional[str]]:
    """
    Non-mutating check used during PREFLIGHT to prioritize resumes.
    Returns (has_resume, tag_hint).
    """
    inprog = snap_dir / f".inprogress-{device}"
    tagf = inprog / ".run-tag"
    try:
        if tagf.exists():
            tag = tagf.read_text(encoding="utf-8").strip()
            if tag:
                return True, tag
        if _inprogress_payload_present(inprog):
            return True, None
    except Exception:
        pass
    return False, None


def load_or_create_run_tag(inprog: Path) -> tuple[str, bool, bool]:
    """
    Returns (tag, resumed, created_now)
      - resumed=True means we are resuming a prior in-progress directory.
      - created_now=True means we created .run-tag during this invocation.
    """
    tag_file = inprog / ".run-tag"
    if tag_file.exists():
        try:
            tag = tag_file.read_text(encoding="utf-8").strip()
            if tag:
                return tag, True, False
        except Exception:
            # treat as missing/empty; fallthrough to creation
            pass

    # If dir already contains payload, treat as resume even if .run-tag is missing/empty
    resumed = _inprogress_payload_present(inprog)

    tag = utc_tag()
    safe_mkdir(inprog, parents=True)
    try:
        tag_file.write_text(tag + "\n", encoding="utf-8")
    except Exception:
        # If tag write fails we still continue; run will be "new" but inprog may exist.
        pass
    return tag, resumed, True


def clear_run_tag_in_tree(tree: Path) -> None:
    try:
        (tree / ".run-tag").unlink(missing_ok=True)
    except Exception:
        pass


def cleanup_new_empty_inprogress(inprog: Path) -> None:
    """
    Best-effort cleanup if we created an in-progress dir/tag this run but did not transfer anything.
    Only removes if it looks empty-ish (i.e., no real payload).
    """
    try:
        tagf = inprog / ".run-tag"
        entries = [p.name for p in inprog.iterdir()]
        allowed = {".run-tag", ".rsync-partial"}
        if all(n in allowed for n in entries):
            try:
                tagf.unlink(missing_ok=True)
            except Exception:
                pass
            rp = inprog / ".rsync-partial"
            if rp.exists():
                shutil.rmtree(rp, ignore_errors=True)
            inprog.rmdir()
    except Exception:
        pass


# ----------------------------
# Dual logger
# ----------------------------

class DualLogger:
    def __init__(self, *, job: str, log_fp):
        self.job = job
        self.fp = log_fp

    def _emit(self, line: str) -> None:
        if not line.endswith("\n"):
            line += "\n"
        sys.stdout.write(line)
        sys.stdout.flush()
        self.fp.write(line)
        self.fp.flush()

    def state(self, state: str, msg: str) -> None:
        ts = utc_now().strftime("%F %T")
        self._emit(f"[{ts} UTC] [{self.job}] {state}: {msg}")

    def raw(self, text: str) -> None:
        if text == "":
            return
        if not text.endswith("\n"):
            text += "\n"
        sys.stdout.write(text)
        sys.stdout.flush()
        self.fp.write(text)
        self.fp.flush()


# ----------------------------
# Progress helpers (bytes so far)
# ----------------------------

def _fmt_bytes(n: int) -> str:
    units = ["B", "KiB", "MiB", "GiB", "TiB", "PiB"]
    x = float(n)
    for u in units:
        if x < 1024.0:
            if u == "B":
                return f"{int(x)}{u}"
            return f"{x:.2f}{u}"
        x /= 1024.0
    return f"{x:.2f}EiB"


def du_bytes(path: Path, *, timeout_s: int) -> Optional[int]:
    """
    Returns apparent size in bytes using `du -sb`.
    None if du missing or fails.
    """
    try:
        p = subprocess.run(
            ["du", "-sb", str(path)],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=timeout_s,
        )
        if p.returncode != 0:
            return None
        first = (p.stdout or "").strip().split(None, 1)[0]
        return int(first)
    except (FileNotFoundError, subprocess.TimeoutExpired, ValueError):
        return None


def adaptive_du_timeout(base_s: int, bytes_hint: Optional[int]) -> int:
    """
    Dynamically increase du timeout as the in-progress tree grows.

    - base_s is the user-configured floor (--du-timeout-s).
    - We scale with log2(size) so it grows gently.
    - Hard-capped to stay safe.
    """
    base = max(1, int(base_s))
    b = max(0, int(bytes_hint or 0))

    hard_cap = max(base, min(180, base * 6))
    if b <= 0:
        return base

    gib = 1024 ** 3
    steps = math.log2(1.0 + (b / gib))
    scaled = int(round(base * (1.0 + 0.35 * steps)))
    return max(base, min(hard_cap, scaled))


# ----------------------------
# Signal-safe runner (process group) + stall watchdog
# ----------------------------

class _Runner:
    def __init__(self) -> None:
        self.child_pgid: Optional[int] = None
        self.signal_seen: Optional[int] = None


RUNNER = _Runner()


def _forward_signal(sig: int, _frame) -> None:
    RUNNER.signal_seen = sig
    if RUNNER.child_pgid is not None:
        try:
            os.killpg(RUNNER.child_pgid, sig)
        except ProcessLookupError:
            pass


def _kill_pgrp(pgid: int, sig: int) -> None:
    try:
        os.killpg(pgid, sig)
    except ProcessLookupError:
        pass


def run_and_tee(
    cmd: list[str],
    log: DualLogger,
    *,
    kill_grace_s: int = 20,
    wallclock_timeout_s: int = 0,
    progress_path: Optional[Path] = None,
    progress_interval_s: int = 60,
    stall_timeout_s: int = 1800,
    du_timeout_s: int = 20,
    enable_progress: bool = True,
) -> tuple[int, Optional[int], str]:
    """
    Runs cmd, tees stdout+stderr into DualLogger.

    Adds:
      - Periodic PROGRESS logging based on bytes in progress_path.
      - Stall watchdog: if bytes haven't increased for stall_timeout_s, kill rsync.

    Returns: (rc, signal_seen, reason)
    """
    import selectors

    old_int = signal.getsignal(signal.SIGINT)
    old_term = signal.getsignal(signal.SIGTERM)
    signal.signal(signal.SIGINT, _forward_signal)
    signal.signal(signal.SIGTERM, _forward_signal)

    start = time.time()
    last_progress_log = 0.0
    last_bytes: Optional[int] = None
    last_change = time.time()

    reason = "unknown"
    rc = 1
    sig_seen: Optional[int] = None

    sel: Optional[selectors.BaseSelector] = None
    p: Optional[subprocess.Popen[str]] = None

    try:
        p = subprocess.Popen(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            bufsize=1,
            start_new_session=True,
        )
        assert p.stdout is not None
        RUNNER.child_pgid = os.getpgid(p.pid)
        RUNNER.signal_seen = None

        sel = selectors.DefaultSelector()
        sel.register(p.stdout, selectors.EVENT_READ)

        while True:
            if p.poll() is not None:
                try:
                    rest = p.stdout.read()
                    if rest:
                        log.raw(rest)
                except Exception:
                    pass
                break

            now = time.time()

            if wallclock_timeout_s > 0 and (now - start) > wallclock_timeout_s:
                reason = "wallclock_timeout"
                log.state("RUN_TIMEOUT", f"wallclock timeout exceeded ({wallclock_timeout_s}s); terminating rsync")
                _kill_pgrp(RUNNER.child_pgid, signal.SIGTERM)
                t0 = time.time()
                while time.time() - t0 < kill_grace_s:
                    if p.poll() is not None:
                        break
                    time.sleep(0.2)
                if p.poll() is None:
                    log.state("RUN_TIMEOUT", "rsync did not exit after SIGTERM; sending SIGKILL")
                    _kill_pgrp(RUNNER.child_pgid, signal.SIGKILL)
                break

            if enable_progress and progress_path and progress_interval_s > 0 and (now - last_progress_log) >= progress_interval_s:
                du_to = adaptive_du_timeout(du_timeout_s, last_bytes)
                b = du_bytes(progress_path, timeout_s=du_to)
                if b is not None:
                    if last_bytes is None:
                        last_bytes = b
                        last_change = now
                    else:
                        if b > last_bytes:
                            last_change = now
                        delta = b - last_bytes
                        elapsed = max(1e-6, (now - last_progress_log) if last_progress_log > 0 else (now - start))
                        rate = delta / elapsed
                        last_bytes = b
                        log.state(
                            "PROGRESS",
                            f"bytes={_fmt_bytes(b)} rate={_fmt_bytes(int(rate))}/s stall_for={int(now - last_change)}s du_timeout={du_to}s",
                        )

                    if stall_timeout_s > 0 and (now - last_change) >= stall_timeout_s:
                        reason = "stall_timeout"
                        log.state(
                            "RUN_STALL",
                            f"no dest byte growth for {int(now - last_change)}s (>= {stall_timeout_s}s) -> terminating rsync",
                        )
                        _kill_pgrp(RUNNER.child_pgid, signal.SIGTERM)
                        t0 = time.time()
                        while time.time() - t0 < kill_grace_s:
                            if p.poll() is not None:
                                break
                            time.sleep(0.2)
                        if p.poll() is None:
                            log.state("RUN_STALL", "rsync did not exit after SIGTERM; sending SIGKILL")
                            _kill_pgrp(RUNNER.child_pgid, signal.SIGKILL)
                        break
                else:
                    log.state("PROGRESS", f"du_bytes unavailable (no du / timed out) du_timeout={du_to}s")

                last_progress_log = now

            assert sel is not None
            events = sel.select(timeout=0.5)
            if not events:
                continue

            for key, _mask in events:
                try:
                    chunk = key.fileobj.readline()
                except Exception:
                    chunk = ""
                if chunk:
                    chunk = chunk.replace("\r", "\n")
                    log.raw(chunk)

        rc = p.wait()
        sig_seen = RUNNER.signal_seen
        if sig_seen is not None:
            reason = f"signal_{sig_seen}"
        elif reason in ("wallclock_timeout", "stall_timeout"):
            if rc == 0:
                rc = 124
        else:
            reason = "exit"

        return rc, sig_seen, reason

    finally:
        if sel is not None:
            try:
                sel.close()
            except Exception:
                pass

        if RUNNER.child_pgid is not None:
            try:
                os.killpg(RUNNER.child_pgid, 0)
            except ProcessLookupError:
                pass
            else:
                _kill_pgrp(RUNNER.child_pgid, signal.SIGTERM)
                t0 = time.time()
                while time.time() - t0 < kill_grace_s:
                    try:
                        os.killpg(RUNNER.child_pgid, 0)
                    except ProcessLookupError:
                        break
                    time.sleep(0.2)
                else:
                    _kill_pgrp(RUNNER.child_pgid, signal.SIGKILL)

        RUNNER.child_pgid = None
        RUNNER.signal_seen = None
        signal.signal(signal.SIGINT, old_int)
        signal.signal(signal.SIGTERM, old_term)


# ----------------------------
# Load-shedding
# ----------------------------

def wait_for_load(max_load: float, log: DualLogger, poll_s: int = 10) -> None:
    if max_load <= 0:
        return
    warned = False
    while True:
        try:
            one, _five, _fifteen = os.getloadavg()
        except OSError:
            return
        if one <= max_load:
            return
        if not warned:
            log.state("LOAD_WAIT", f"loadavg(1m)={one:.2f} > max_load={max_load:.2f}; waiting")
            warned = True
        time.sleep(max(1, poll_s))


# ----------------------------
# Jobs config
# ----------------------------

@dataclass(frozen=True)
class Job:
    device: str
    ssh: str
    path: str
    when: str
    description: str
    klass: str
    keep: int
    action: str


def parse_jobs(cfg: dict[str, Any], defaults: dict[str, Any]) -> list[Job]:
    jobs_raw = cfg.get("job", [])
    if not isinstance(jobs_raw, list):
        raise RuntimeError("jobs.toml must contain one or more [[job]] tables")
    out: list[Job] = []
    for j in jobs_raw:
        if not isinstance(j, dict):
            continue
        device = str(j.get("device", "")).strip()
        if not device:
            continue
        sshv = str(j.get("ssh", device)).strip()
        path = str(j.get("path", f"/home/{device}/")).strip()
        if not path.endswith("/"):
            path += "/"
        when = str(j.get("when", "daily")).strip()
        desc = str(j.get("description", "")).strip()
        klass = str(j.get("class", defaults["class"])).strip()
        keep = int(j.get("keep", defaults["keep"]))
        if keep < 1:
            keep = 1
        action = str(j.get("action", defaults["action"])).strip()
        out.append(Job(device, sshv, path, when, desc, klass, keep, action))
    return out


# ----------------------------
# Job outcome + summary
# ----------------------------

class Outcome(Enum):
    SUCCESS = "success"
    SOFT_SUCCESS = "soft_success"
    FAILED = "failed"
    SKIPPED = "skipped"
    DEFERRED = "deferred"


@dataclass
class JobSummary:
    job: Job
    outcome: Outcome
    reason: str
    tag: Optional[str]
    started: Optional[dt.datetime]
    ended: Optional[dt.datetime]
    attempts: int


def _fmt_dur(s: JobSummary) -> str:
    if not s.started or not s.ended:
        return "-"
    sec = (s.ended - s.started).total_seconds()
    if sec < 0:
        return "-"
    if sec < 60:
        return f"{int(sec)}s"
    if sec < 3600:
        return f"{int(sec//60)}m{int(sec%60)}s"
    return f"{int(sec//3600)}h{int((sec%3600)//60)}m"


def _worst_outcome(a: Outcome, b: Outcome) -> Outcome:
    rank = {
        Outcome.FAILED: 5,
        Outcome.DEFERRED: 4,
        Outcome.SOFT_SUCCESS: 3,
        Outcome.SUCCESS: 2,
        Outcome.SKIPPED: 1,
    }
    return a if rank[a] >= rank[b] else b


def collapse_summaries_by_device(summaries: list[JobSummary]) -> list[JobSummary]:
    """
    Collapse multiple entries for the same device into one line-item while preserving
    the "worst" outcome and surfacing all reasons/tags.
    """
    by_dev: dict[str, list[JobSummary]] = {}
    for s in summaries:
        by_dev.setdefault(s.job.device, []).append(s)

    out: list[JobSummary] = []
    for dev, items in sorted(by_dev.items(), key=lambda kv: kv[0]):
        worst = items[0].outcome
        for it in items[1:]:
            worst = _worst_outcome(worst, it.outcome)

        reasons: list[str] = []
        for it in items:
            if it.reason and it.reason not in reasons:
                reasons.append(it.reason)

        tag = None
        for it in items:
            if it.tag:
                tag = it.tag
                break

        attempts = sum(max(0, int(it.attempts)) for it in items)

        started = None
        ended = None
        total_sec = 0.0
        for it in items:
            if it.started and it.ended:
                total_sec += max(0.0, (it.ended - it.started).total_seconds())
        if total_sec > 0:
            started = utc_now()
            ended = started + dt.timedelta(seconds=total_sec)

        rep = items[0].job
        out.append(
            JobSummary(
                rep,
                worst,
                "+".join(reasons) if reasons else worst.value,
                tag,
                started,
                ended,
                attempts,
            )
        )
    return out


def _ascii_table(rows: list[list[str]], headers: list[str]) -> str:
    cols = len(headers)
    widths = [len(h) for h in headers]
    for r in rows:
        for i in range(cols):
            widths[i] = max(widths[i], len(r[i]))

    def sep(ch: str = "-") -> str:
        return "+ " + " + ".join(ch * w for w in widths) + " +"

    def fmt_row(r: list[str]) -> str:
        return "| " + " | ".join(r[i].ljust(widths[i]) for i in range(cols)) + " |"

    out: list[str] = []
    out.append(sep("-"))
    out.append(fmt_row(headers))
    out.append(sep("="))
    for r in rows:
        out.append(fmt_row(r))
    out.append(sep("-"))
    return "\n".join(out)


# ----------------------------
# Job metadata + ordering
# ----------------------------

@dataclass
class JobMeta:
    resumable: bool
    resumable_tag_hint: Optional[str]
    snap_count: int
    last_snap_dt: Optional[dt.datetime]
    prior_failure: bool


def job_snap_dir(backups_root: Path, j: Job) -> Path:
    return backups_root / j.klass / j.device / "snapshots"


def job_legacy_dir(backups_root: Path, j: Job) -> Path:
    return backups_root / "legacy" / j.klass / j.device


def collect_job_meta(backups_root: Path, state_dir: Path, j: Job) -> JobMeta:
    snap_dir = job_snap_dir(backups_root, j)
    has_r, hint = has_resumable_inprogress(snap_dir, j.device)

    snap_count = 0
    last_dt: Optional[dt.datetime] = None
    try:
        snaps = [p for p in safe_list_dirs(snap_dir) if p.name.startswith("20")]
        snap_count = len(snaps)
        if snaps:
            # newest by name (tag format sorts lexicographically)
            newest = sorted(snaps, key=lambda p: p.name)[-1].name
            last_dt = parse_utc_tag(newest)
    except Exception:
        pass

    pf = has_prior_failure(state_dir, j.device)
    return JobMeta(has_r, hint, snap_count, last_dt, pf)


def priority_tuple(j: Job, m: JobMeta) -> tuple:
    """
    Lower tuple sorts earlier (higher priority).
    Desired:
      1) resumables first
      2) prior failures next
      3) oldest last snapshot next (older => higher priority)
      4) fewer snapshots next (more snapshots => lower priority)
      5) stable device name tie-breaker
    """
    # Age: if no last snapshot => treat as very old => very high priority
    now = utc_now()
    if m.last_snap_dt is None:
        age_sec = 10**12
    else:
        age = now - m.last_snap_dt
        age_sec = max(0.0, age.total_seconds())

    # We want older => earlier, so sort by negative age
    return (
        0 if m.resumable else 1,
        0 if m.prior_failure else 1,
        -age_sec,
        m.snap_count,
        j.device,
    )


# ----------------------------
# Legacy -> archive worker (idle-time)
# ----------------------------

def _which(cmd: str) -> Optional[str]:
    try:
        return shutil.which(cmd)
    except Exception:
        return None


def _iter_legacy_snapshots(backups_root: Path) -> list[tuple[str, str, Path]]:
    """
    Returns list of (klass, device, snapshot_dir_path) for legacy snapshots.
    snapshot_dir_path points to .../legacy/<klass>/<device>/<tag>
    """
    out: list[tuple[str, str, Path]] = []
    legacy_root = backups_root / "legacy"
    try:
        if not legacy_root.exists():
            return out
        for klass_dir in sorted([p for p in legacy_root.iterdir() if p.is_dir()]):
            klass = klass_dir.name
            for dev_dir in sorted([p for p in klass_dir.iterdir() if p.is_dir()]):
                device = dev_dir.name
                for snap in sorted([p for p in dev_dir.iterdir() if p.is_dir() and p.name.startswith("20")]):
                    out.append((klass, device, snap))
    except Exception:
        return out
    return out


def archive_legacy_on_idle(
    backups_root: Path,
    *,
    level: int,
    max_items: int,
    max_total_bytes: int,
    du_timeout_s: int,
) -> None:
    """
    Compress legacy snapshots into archives/<klass>/<device>/<tag>.tar.zst.
    Conservative and best-effort; will not raise for typical failures.
    Requires external tar+zstd.
    zstd -# compression levels are standard CLI behavior. :contentReference[oaicite:1]{index=1}
    """
    ts = utc_now().strftime("%F %T")

    if _which("tar") is None or _which("zstd") is None:
        print(f"[{ts} UTC] [idle] ARCHIVE: tar/zstd not available; skipping legacy archive worker")
        return

    archives_root = backups_root / "archives"
    legacy_items = _iter_legacy_snapshots(backups_root)
    if not legacy_items:
        print(f"[{ts} UTC] [idle] ARCHIVE: no legacy snapshots found")
        return

    # Oldest first (by tag parse if possible, else by mtime)
    def key_item(item: tuple[str, str, Path]) -> tuple:
        _klass, _dev, p = item
        d = parse_utc_tag(p.name)
        if d is not None:
            return (0, d)
        try:
            return (1, dt.datetime.fromtimestamp(p.stat().st_mtime, tz=dt.timezone.utc))
        except Exception:
            return (2, dt.datetime(1970, 1, 1, tzinfo=dt.timezone.utc))

    legacy_items.sort(key=key_item)

    done = 0
    used_bytes = 0

    for klass, dev, snapdir in legacy_items:
        if done >= max_items:
            break

        # Estimate size for budgeting
        est = du_bytes(snapdir, timeout_s=du_timeout_s)
        if est is None:
            est = 0

        if max_total_bytes > 0 and (used_bytes + est) > max_total_bytes and done > 0:
            print(f"[{ts} UTC] [idle] ARCHIVE: budget reached; stopping (used={used_bytes}B cap={max_total_bytes}B)")
            break

        out_dir = archives_root / klass / dev
        safe_mkdir(out_dir, parents=True)

        dest = out_dir / f"{snapdir.name}.tar.zst"
        tmp = out_dir / f".{snapdir.name}.tar.zst.tmp"

        if dest.exists():
            # Already archived; remove legacy dir to reclaim space (best-effort).
            try:
                if dest.stat().st_size > 0:
                    print(f"[{ts} UTC] [idle] ARCHIVE: already archived {dest}; removing legacy {snapdir}")
                    shutil.rmtree(snapdir, ignore_errors=True)
                    done += 1
                    continue
            except Exception:
                pass

        # tar from parent directory so archive root contains <tag>/...
        parent = snapdir.parent
        tagname = snapdir.name

        print(f"[{ts} UTC] [idle] ARCHIVE: {klass}/{dev}/{tagname} -> {dest} (zstd level {level})")

        try:
            if tmp.exists():
                tmp.unlink()
        except Exception:
            pass

        # tar -C <parent> -cf - <tagname> | zstd -12 -T0 -q -o <tmp>
        tar_cmd = ["tar", "-C", str(parent), "-cf", "-", tagname]
        zstd_cmd = ["zstd", f"-{int(level)}", "-T0", "-q", "-o", str(tmp)]

        try:
            p1 = subprocess.Popen(tar_cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
            assert p1.stdout is not None
            p2 = subprocess.Popen(zstd_cmd, stdin=p1.stdout, stdout=subprocess.DEVNULL, stderr=subprocess.PIPE)
            p1.stdout.close()

            _t_err = p1.stderr.read().decode("utf-8", errors="replace") if p1.stderr else ""
            _z_err = p2.stderr.read().decode("utf-8", errors="replace") if p2.stderr else ""

            rc1 = p1.wait()
            rc2 = p2.wait()

            if rc1 != 0 or rc2 != 0:
                print(f"[{ts} UTC] [idle] ARCHIVE: FAILED rc_tar={rc1} rc_zstd={rc2}")
                if _t_err.strip():
                    print(f"[{ts} UTC] [idle] ARCHIVE: tar stderr: {_t_err.strip()}")
                if _z_err.strip():
                    print(f"[{ts} UTC] [idle] ARCHIVE: zstd stderr: {_z_err.strip()}")
                try:
                    tmp.unlink(missing_ok=True)
                except Exception:
                    pass
                continue

            try:
                if tmp.stat().st_size <= 0:
                    print(f"[{ts} UTC] [idle] ARCHIVE: FAILED produced empty archive; keeping legacy {snapdir}")
                    tmp.unlink(missing_ok=True)
                    continue
            except Exception:
                pass

            try:
                tmp.replace(dest)
            except Exception:
                # fallback to copy+unlink
                shutil.copy2(tmp, dest)
                tmp.unlink(missing_ok=True)

            # Remove legacy snapshot directory after successful archive
            shutil.rmtree(snapdir, ignore_errors=True)

            used_bytes += est
            done += 1

        except Exception as e:
            print(f"[{ts} UTC] [idle] ARCHIVE: exception: {e}")
            try:
                tmp.unlink(missing_ok=True)
            except Exception:
                pass
            continue

    if done > 0:
        print(f"[{ts} UTC] [idle] ARCHIVE: completed {done} item(s)")
    else:
        print(f"[{ts} UTC] [idle] ARCHIVE: no items archived this run")


# ----------------------------
# Main per-job runner
# ----------------------------

def run_one_job(
    job: Job,
    *,
    backups_root: Path,
    state_dir: Path,
    ssh_config: Optional[Path],
    args,
) -> JobSummary:
    started = utc_now()

    dev_dir = backups_root / job.klass / job.device
    snap_dir = dev_dir / "snapshots"
    log_dir = dev_dir / "logs"
    inprog = snap_dir / f".inprogress-{job.device}"
    legacy_root = backups_root / "legacy" / job.klass / job.device

    for p in (dev_dir, snap_dir, log_dir, inprog, legacy_root):
        ensure_under(backups_root, p)

    safe_mkdir(log_dir, parents=True)
    safe_mkdir(snap_dir, parents=True)

    tag, resumed, created_now = load_or_create_run_tag(inprog)
    log_file = log_dir / f"backup-{job.device}-{tag}.log"
    attempts = 0

    transient_seen: list[int] = []
    precheck_failures: int = 0

    with open(log_file, "a" if log_file.exists() else "w", encoding="utf-8") as log_fp:
        log = DualLogger(job=job.device, log_fp=log_fp)
        src = f"{job.ssh}:{job.path}"

        log.state("JOB_START", f"{'resume' if resumed else 'start'} tag={tag} class={job.klass} src={src}")
        if job.description:
            log.state("JOB_INFO", f"description={job.description}")

        deep = bool(args.deep_verify or has_prior_failure(state_dir, job.device))

        snaps = sorted([p for p in safe_list_dirs(snap_dir) if p.name.startswith("20")])
        last_snap = snaps[-1] if snaps else None

        rsync_opts = [
            "-aHAXx",
            "--numeric-ids",
            "--partial",
            "--partial-dir=.rsync-partial",
            "--info=stats2,name0",
            "--human-readable",
        ]
        if not args.no_compress:
            rsync_opts.append("--compress")

        if args.rsync_timeout and args.rsync_timeout > 0:
            rsync_opts.append(f"--timeout={args.rsync_timeout}")

        if args.rsync_stop_after_mins and args.rsync_stop_after_mins > 0:
            rsync_opts.append(f"--stop-after={args.rsync_stop_after_mins}")

        if args.bwlimit and args.bwlimit > 0:
            rsync_opts.append(f"--bwlimit={args.bwlimit}")

        if deep:
            rsync_opts.append("--checksum")
            log.state("JOB_MODE", "deep-verify enabled (--checksum) due to prior failure or flag")
        if last_snap:
            rsync_opts.append(f"--link-dest={last_snap}")

        safe_mkdir(inprog, parents=True)

        ssh_str = "ssh -o BatchMode=yes -o ConnectTimeout=8 -o ServerAliveInterval=5 -o ServerAliveCountMax=2"
        if ssh_config and ssh_config.exists():
            ssh_str += f" -F {shlex.quote(str(ssh_config))}"

        cmd = ["rsync"] + rsync_opts + ["-e", ssh_str, src, str(inprog) + "/"]

        soft_success_rcs = set() if args.strict_rsync else {23, 24}
        transient_rcs = {12, 30, 35, 255}

        soft_succeeded = False
        final_rc: Optional[int] = None

        while attempts < max(1, args.attempts):
            attempts += 1

            wait_for_load(args.max_load, log, poll_s=max(1, args.load_poll))

            log.state("RUN_PRECHECK", f"attempt={attempts}: probing (ssh+rsync-ready)")
            ok, out = rsync_ready_probe(job.ssh, ssh_config, timeout_s=args.ssh_probe_timeout)
            if out.strip():
                for line in out.splitlines():
                    log.raw(f"[probe] {line}")

            if not ok:
                precheck_failures += 1
                log.state("RUN_DEFER", f"endpoint not rsync-ready; deferring in this pass (attempt={attempts})")
                mark_failure(state_dir, job.device, "ssh_or_rsync_unreachable")
                prune_logs(log_dir, args.log_days)

                if created_now and not resumed:
                    log.state("CLEANUP", "removing newly-created empty in-progress dir (deferred before transfer)")
                    cleanup_new_empty_inprogress(inprog)

                ended = utc_now()
                extra = []
                if precheck_failures > 1:
                    extra.append(f"precheck_fails={precheck_failures}")
                if transient_seen:
                    extra.append("transient=" + ",".join(str(x) for x in transient_seen))
                reason = "ssh_or_rsync_unreachable"
                if extra:
                    reason += " (" + " ".join(extra) + ")"
                return JobSummary(job, Outcome.DEFERRED, reason, tag, started, ended, attempts)

            log.state("RUN_START", f"attempt={attempts}: running rsync (cmd below)")
            log.raw("[cmd] " + " ".join(shlex.quote(c) for c in cmd))

            wall_s = int(args.wallclock_timeout_s) if args.wallclock_timeout_s else 0
            rc, sig_seen, why = run_and_tee(
                cmd,
                log,
                kill_grace_s=args.kill_grace_s,
                wallclock_timeout_s=wall_s,
                progress_path=inprog,
                progress_interval_s=args.progress_interval_s,
                stall_timeout_s=args.stall_timeout_s,
                du_timeout_s=args.du_timeout_s,
                enable_progress=(not args.no_progress),
            )
            final_rc = rc

            if sig_seen is not None or rc == 20:
                log.state("RUN_INTERRUPTED", f"signal={sig_seen} rc={rc}; leaving partials for resume in {inprog}")
                mark_failure(state_dir, job.device, "interrupted")
                prune_logs(log_dir, args.log_days)
                ended = utc_now()
                extra = []
                if transient_seen:
                    extra.append("transient=" + ",".join(str(x) for x in transient_seen))
                reason = "interrupted"
                if extra:
                    reason += " (" + " ".join(extra) + ")"
                return JobSummary(job, Outcome.FAILED, reason, tag, started, ended, attempts)

            if rc == 0:
                log.state("RUN_OK", f"rsync rc=0 ({why})")
                break

            if rc in soft_success_rcs:
                soft_succeeded = True
                log.state("RUN_SOFT", f"rsync rc={rc} treated as SOFT_SUCCESS; snapshot will be finalized (may be incomplete)")
                mark_failure(state_dir, job.device, f"soft_rsync_rc_{rc}")
                break

            if rc in transient_rcs:
                transient_seen.append(rc)
                log.state("RUN_RETRY", f"transient rsync rc={rc}; retrying ({attempts}/{args.attempts})")
                mark_failure(state_dir, job.device, f"transient_rsync_rc_{rc}")
                if args.retry_sleep > 0:
                    time.sleep(args.retry_sleep)
                continue

            log.state("RUN_FAIL", f"non-transient rsync rc={rc}; leaving partials in {inprog}")
            mark_failure(state_dir, job.device, f"rsync_rc_{rc}")
            prune_logs(log_dir, args.log_days)
            ended = utc_now()
            reason = f"rsync_rc_{rc}"
            if transient_seen:
                reason += " (transient=" + ",".join(str(x) for x in transient_seen) + ")"
            return JobSummary(job, Outcome.FAILED, reason, tag, started, ended, attempts)

        # Finalize snapshot (on success or soft-success)
        final = snap_dir / tag
        if final.exists():
            shutil.rmtree(final)

        log.state("FINALIZE", f"renaming in-progress -> final: {inprog} -> {final}")
        inprog.rename(final)
        clear_run_tag_in_tree(final)

        cur = snap_dir / "current"
        try:
            if cur.is_symlink() or cur.exists():
                cur.unlink()
        except FileNotFoundError:
            pass
        cur.symlink_to(final)
        log.state("FINALIZE", f"updated current -> {final}")

        # Retention
        # Back-compat: action=quarantine now writes into legacy_root.
        act = (job.action or "").strip().lower()
        if act == "delete" and not args.auto:
            log.state("RETENTION", "action=delete but --auto not set; skipping deletion")
        else:
            retention(snap_dir, legacy_root, job.keep, job.action, log)

        prune_logs(log_dir, args.log_days)

        outcome = Outcome.SOFT_SUCCESS if soft_succeeded else Outcome.SUCCESS

        if soft_succeeded:
            reason = "soft_success"
            if final_rc is not None:
                reason += f"(rc={final_rc})"
            if transient_seen:
                reason += " transient=" + ",".join(str(x) for x in transient_seen)
        else:
            reason = "success"
            if transient_seen:
                reason += " recovered_from=" + ",".join(str(x) for x in transient_seen)
            clear_failure(state_dir, job.device)

        log.state("JOB_DONE", f"outcome={outcome.value} attempts={attempts}")
        ended = utc_now()
        return JobSummary(job, outcome, reason, tag, started, ended, attempts)


# ----------------------------
# Main
# ----------------------------

def main() -> int:
    ap = argparse.ArgumentParser(description="Pull backups over SSH (WireGuard), snapshot+retention.")
    ap.add_argument("--daemon", action="store_true", help="run scheduled jobs from jobs.toml")
    ap.add_argument("--jobs-file", default="/etc/pull-backup/jobs.toml")
    ap.add_argument("--backups-root", default="/srv/storage/backups")
    ap.add_argument("--state-dir", default="/var/lib/pull-backup/state")
    ap.add_argument("--class", dest="klass", default="laptops")
    ap.add_argument("--keep", type=int, default=3)
    # Back-compat: "quarantine" accepted; actual directory is now "legacy/"
    ap.add_argument("--action", choices=["legacy", "quarantine", "delete", "keep"], default="quarantine",
                    help="retention action; 'quarantine' kept for compatibility but now writes into legacy/")
    ap.add_argument("--log-days", type=int, default=30)
    ap.add_argument("--auto", action="store_true", help="allow destructive actions like retention delete")
    ap.add_argument("--deep-verify", action="store_true", help="force rsync --checksum")
    ap.add_argument("--ssh-config", default="/root/.ssh/config")
    ap.add_argument("--lock-file", default="/run/pull-backup/lock")

    ap.add_argument("--attempts", type=int, default=2)
    ap.add_argument("--retry-sleep", type=int, default=10)
    ap.add_argument("--passes", type=int, default=2)
    ap.add_argument("--pass-delay", type=int, default=120)

    ap.add_argument("--ssh-probe-timeout", type=int, default=12)

    ap.add_argument("--rsync-timeout", type=int, default=0,
                    help="rsync --timeout idle-I/O seconds (0 disables; recommended 0 with stall watchdog)")

    ap.add_argument("--rsync-stop-after-mins", type=int, default=0)
    ap.add_argument("--bwlimit", type=int, default=0)
    ap.add_argument("--no-compress", action="store_true")
    ap.add_argument("--strict-rsync", action="store_true")

    ap.add_argument("--wallclock-timeout-s", type=int, default=0)
    ap.add_argument("--kill-grace-s", type=int, default=20)

    ap.add_argument("--max-load", type=float, default=4.0)
    ap.add_argument("--load-poll", type=int, default=10)

    ap.add_argument("--exit-soft-nonzero", action="store_true")

    ap.add_argument("--ignore-when", action="store_true",
                    help="ignore job 'when' schedule and run ALL jobs (manual/test force-run)")

    # Idle behavior knobs
    ap.add_argument("--idle-resume", action="store_true", default=True,
                    help="on off-days, attempt resumable jobs even if schedule doesn't match (default on)")
    ap.add_argument("--idle-resume-max", type=int, default=1,
                    help="max resumable jobs to run when no jobs match today's schedule (default 1; 0 = no limit)")

    ap.add_argument("--archive-legacy-on-idle", action="store_true", default=True,
                    help="when truly idle (no scheduled jobs and no resumables), archive legacy snapshots to archives/ (default on)")
    ap.add_argument("--archive-zstd-level", type=int, default=12,
                    help="zstd compression level for idle archiver (default 12)")
    ap.add_argument("--archive-max-items", type=int, default=1,
                    help="max legacy snapshots to archive per idle run (default 1)")
    ap.add_argument("--archive-max-bytes", type=int, default=50 * 1024**3,
                    help="max estimated bytes to archive per idle run (default 50GiB; 0 disables budget)")

    ap.add_argument("--progress-interval-s", type=int, default=60,
                    help="log bytes-so-far every N seconds (0 disables)")
    ap.add_argument("--stall-timeout-s", type=int, default=1800,
                    help="kill rsync only if dest bytes haven't increased for N seconds (0 disables)")
    ap.add_argument("--du-timeout-s", type=int, default=20,
                    help="base timeout for du progress probe (auto-scales up as the tree grows)")
    ap.add_argument("--no-progress", action="store_true",
                    help="disable PROGRESS logging and stall detection (not recommended)")

    args = ap.parse_args()
    os.umask(0o077)

    backups_root = Path(args.backups_root).resolve()
    if str(backups_root) != "/srv/storage/backups":
        raise RuntimeError("backups-root must be exactly /srv/storage/backups")
    if not args.daemon:
        raise RuntimeError("Use --daemon (this tool is scheduler-driven).")

    lock_path = Path(args.lock_file)
    safe_mkdir(lock_path.parent, parents=True)

    with open(lock_path, "w") as lock_fp:
        fcntl.flock(lock_fp, fcntl.LOCK_EX)

        assert_backups_root_ready(backups_root)

        state_dir = Path(args.state_dir)
        cfg_path = Path(args.jobs_file)
        defaults = {"class": args.klass, "keep": args.keep, "action": args.action}

        cfg = load_toml(cfg_path)
        jobs_all = parse_jobs(cfg, defaults)

        # Print failure summary early for visibility
        failures = read_failures_summary(state_dir)
        ts = utc_now().strftime("%F %T")
        if failures:
            print(f"[{ts} UTC] [state] prior failures:")
            for dev, last_time, reason, count in failures:
                print(f"[{ts} UTC] [state]  - {dev}: last_time={last_time} count={count} reason={reason}")

        if args.ignore_when:
            ts = utc_now().strftime("%F %T")
            print(f"[{ts} UTC] [daemon] IGNORE_WHEN: running all jobs regardless of schedule")

        # Build meta for all jobs (so resumables are detected even if schedule doesn't match)
        metas: dict[str, JobMeta] = {}
        for j in jobs_all:
            metas[j.device] = collect_job_meta(backups_root, state_dir, j)

        ssh_config = Path(args.ssh_config) if args.ssh_config else None

        # Determine scheduled vs skipped
        scheduled: list[Job] = []
        skipped: list[Job] = []
        for j in jobs_all:
            if args.ignore_when or when_matches_today(j.when):
                scheduled.append(j)
            else:
                skipped.append(j)

        # Resumables: if enabled, we will run them regardless of schedule
        resumables: list[Job] = []
        for j in jobs_all:
            m = metas.get(j.device)
            if m and m.resumable:
                resumables.append(j)

        # Compute runnable set
        if args.ignore_when:
            runnable = list(jobs_all)
            skipped = []
        else:
            runnable = []
            seen: set[str] = set()
            for j in scheduled:
                if j.device not in seen:
                    runnable.append(j)
                    seen.add(j.device)

            # On off-days, include resumables even if scheduled list empty
            # Also include resumables on normal days (prioritize resume).
            if args.idle_resume or scheduled:
                for j in resumables:
                    if j.device not in seen:
                        runnable.append(j)
                        seen.add(j.device)

        # Log skips (only those truly skipped: not scheduled and no resume, unless ignore_when)
        if not args.ignore_when:
            ts = utc_now().strftime("%F %T")
            for j in skipped:
                m = metas.get(j.device)
                if m and m.resumable:
                    # Not really skipped; will run as resume
                    continue
                print(f"[{ts} UTC] [daemon] skip {j.device} (when={j.when})")

        # If nothing runnable, we are truly idle: archive legacy, then exit
        if not runnable:
            ts = utc_now().strftime("%F %T")
            print(f"[{ts} UTC] [daemon] no jobs to run today (no scheduled and no resumables)")
            if args.archive_legacy_on_idle:
                archive_legacy_on_idle(
                    backups_root,
                    level=max(1, min(22, int(args.archive_zstd_level))),
                    max_items=max(0, int(args.archive_max_items)),
                    max_total_bytes=max(0, int(args.archive_max_bytes)),
                    du_timeout_s=max(5, int(args.du_timeout_s)),
                )
            return 0

        # If there are no scheduled jobs today but we are going to do resumables,
        # optionally cap how many we run to avoid overloading the host.
        if (not args.ignore_when) and (len(scheduled) == 0) and resumables:
            cap = int(args.idle_resume_max)
            if cap > 0 and len(runnable) > cap:
                # Prefer highest priority resumables according to our priority scheme
                runnable.sort(key=lambda j: priority_tuple(j, metas.get(j.device, JobMeta(False, None, 0, None, False))))
                runnable = runnable[:cap]
                ts = utc_now().strftime("%F %T")
                print(f"[{ts} UTC] [idle] RESUME_CAP: limiting resumables to {cap} job(s) this run")

        # Announce detected resumables
        res_list = [j for j in runnable if metas.get(j.device, JobMeta(False, None, 0, None, False)).resumable]
        if res_list:
            ts = utc_now().strftime("%F %T")
            for j in res_list:
                m = metas.get(j.device)
                hint = m.resumable_tag_hint if m else None
                hint_s = f" tag_hint={hint}" if hint else ""
                print(f"[{ts} UTC] [run] RESUME_DETECT: {j.device}{hint_s}")

        # Prepare summaries; skipped jobs are still surfaced as SKIPPED
        summaries: list[JobSummary] = []
        if not args.ignore_when:
            for j in skipped:
                m = metas.get(j.device)
                if m and m.resumable:
                    continue
                summaries.append(JobSummary(j, Outcome.SKIPPED, f"when={j.when}", None, None, None, 0))

        # Dynamic pass loop:
        # Each pass re-probes reachability for remaining jobs, sorts reachable by priority, runs them.
        passes = max(1, int(args.passes))
        pending: list[Job] = list(runnable)

        for pidx in range(passes):
            pass_no = pidx + 1
            ts = utc_now().strftime("%F %T")
            print(f"[{ts} UTC] [run] PASS_START: {pass_no}/{passes} candidates={len(pending)}")

            if not pending:
                print(f"[{ts} UTC] [run] PASS_EMPTY: nothing to run in pass {pass_no}")
                continue

            # Probe reachability for all pending jobs
            print(f"[{ts} UTC] [run] PREFLIGHT: probing {len(pending)} endpoints (ssh+rsync-ready)")
            reachable: list[Job] = []
            unreachable: list[tuple[Job, str]] = []

            for j in pending:
                ok, out = rsync_ready_probe(j.ssh, ssh_config, timeout_s=args.ssh_probe_timeout)
                if ok:
                    reachable.append(j)
                else:
                    reason = "not_rsync_ready"
                    if out.strip():
                        reason = "not_rsync_ready_with_output"
                    unreachable.append((j, reason))

            ts = utc_now().strftime("%F %T")
            print(f"[{ts} UTC] [run] PREFLIGHT: reachable={len(reachable)} unreachable={len(unreachable)}")
            for j, r in unreachable:
                print(f"[{ts} UTC] [run] PREFLIGHT_DEFER: {j.device} ({j.ssh}) reason={r}")

            # Refresh metas for pending devices (resumable might flip, last snapshot may update after earlier pass)
            for j in pending:
                metas[j.device] = collect_job_meta(backups_root, state_dir, j)

            # Order reachable jobs by priority tuple
            reachable_sorted = sorted(reachable, key=lambda j: priority_tuple(j, metas.get(j.device, JobMeta(False, None, 0, None, False))))

            ts = utc_now().strftime("%F %T")
            if reachable_sorted:
                print(f"[{ts} UTC] [run] PREFLIGHT_ORDER: reachable run order:")
                for j in reachable_sorted:
                    m = metas.get(j.device, JobMeta(False, None, 0, None, False))
                    last = m.last_snap_dt.isoformat() if m.last_snap_dt else "-"
                    flags = []
                    if m.resumable:
                        flags.append("RESUME")
                    if m.prior_failure:
                        flags.append("PRIOR_FAIL")
                    flags_s = ",".join(flags) if flags else "normal"
                    print(f"[{ts} UTC] [run]  - {j.device} ({flags_s}) snaps={m.snap_count} last={last}")

            next_pending: list[Job] = []
            # Unreachable automatically go to next pending
            next_pending.extend([j for (j, _r) in unreachable])

            if reachable_sorted:
                for job in reachable_sorted:
                    s = run_one_job(
                        job,
                        backups_root=backups_root,
                        state_dir=state_dir,
                        ssh_config=ssh_config,
                        args=args,
                    )
                    summaries.append(s)

                    # If this run deferred, keep it for another pass
                    if s.outcome == Outcome.DEFERRED and pass_no < passes:
                        next_pending.append(job)

            pending = next_pending

            ts = utc_now().strftime("%F %T")
            print(f"[{ts} UTC] [run] PASS_END: {pass_no}/{passes} deferred_for_next_pass={len(pending)}")

            if pass_no < passes and args.pass_delay > 0 and pending:
                print(f"[{ts} UTC] [run] PASS_SLEEP: sleeping {args.pass_delay}s before next pass")
                time.sleep(args.pass_delay)

        # Summary (unchanged)
        collapsed = collapse_summaries_by_device(summaries)
        hard_fail = any(s.outcome == Outcome.FAILED for s in collapsed)
        soft = any(s.outcome == Outcome.SOFT_SUCCESS for s in collapsed)

        counts = {o: 0 for o in Outcome}
        for s in collapsed:
            counts[s.outcome] += 1

        rows: list[list[str]] = []
        for s in collapsed:
            rows.append([
                s.job.device,
                s.outcome.value,
                str(s.attempts),
                _fmt_dur(s),
                (s.tag or "-"),
                (s.reason or "-"),
            ])

        ts = utc_now().strftime("%F %T")
        print(f"[{ts} UTC] [summary] ------------------------------")
        print(f"[{ts} UTC] [summary] totals: "
              f"success={counts[Outcome.SUCCESS]} "
              f"soft_success={counts[Outcome.SOFT_SUCCESS]} "
              f"failed={counts[Outcome.FAILED]} "
              f"deferred={counts[Outcome.DEFERRED]} "
              f"skipped={counts[Outcome.SKIPPED]}")
        print(_ascii_table(rows, headers=["device", "outcome", "attempts", "dur", "tag", "issues"]))
        print(f"[{ts} UTC] [summary] ------------------------------")

        if hard_fail:
            return 1
        if soft and args.exit_soft_nonzero:
            return 2
        return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except RuntimeError as e:
        print(f"[fatal] {e}", file=sys.stderr)
        msg = str(e).lower()
        if "backup filesystem not available" in msg or "stale mount" in msg:
            raise SystemExit(3)
        raise SystemExit(4)
    except Exception as e:
        print(f"[fatal] {e}", file=sys.stderr)
        raise SystemExit(1)

