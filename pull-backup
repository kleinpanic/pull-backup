def load_toml(path: Path) -> dict[str, Any]:
    data = path.read_bytes()
    try:
        import tomllib  # py3.11+
        return tomllib.loads(data.decode("utf-8"))
    except Exception:
        try:
            import tomli  # type: ignore
            return tomli.loads(data.decode("utf-8"))
        except Exception as e:
            raise RuntimeError(f"Failed to parse TOML: {path} ({e})")


# ----------------------------
# Time helpers
# ----------------------------

def now_local() -> dt.datetime:
    return dt.datetime.now().astimezone()


def utc_now() -> dt.datetime:
    return dt.datetime.now(dt.timezone.utc)


def utc_tag() -> str:
    return utc_now().strftime("%Y%m%d-%H%M%SZ")


def iso_wd_and_name_local() -> Tuple[str, str]:
    n = now_local()
    return str(n.isoweekday()), n.strftime("%a")


def parse_utc_tag(s: str) -> Optional[dt.datetime]:
    """
    Parse snapshot tag directory names of form YYYYmmdd-HHMMSSZ (UTC).
    Returns UTC datetime or None.
    """
    try:
        return dt.datetime.strptime(s, "%Y%m%d-%H%M%SZ").replace(tzinfo=dt.timezone.utc)
    except Exception:
        return None


# ----------------------------
# Schedule matching
# ----------------------------

def when_matches_today(when: str) -> bool:
    when = (when or "").strip().strip('"').strip("'")
    if when == "" or when == "*" or when.lower() == "daily":
        return True
    iso, name = iso_wd_and_name_local()
    parts = [p.strip() for p in when.split(",") if p.strip()]
    for p in parts:
        if p == iso or p.lower() == name.lower():
            return True
    return False


# ----------------------------
# State tracking (OFF backup mount)
# ----------------------------

def state_file(state_dir: Path, device: str) -> Path:
    return state_dir / f"{device}.failure"


def has_prior_failure(state_dir: Path, device: str) -> bool:
    f = state_file(state_dir, device)
    try:
        return f.exists()
    except OSError:
        return False


def mark_failure(state_dir: Path, device: str, reason: str) -> None:
    safe_mkdir(state_dir, parents=True)
    f = state_file(state_dir, device)
    count = 0
    if f.exists():
        try:
            for line in f.read_text(encoding="utf-8").splitlines():
                if line.startswith("count="):
                    count = int(line.split("=", 1)[1].strip())
        except Exception:
            count = 0
    count += 1
    f.write_text(
        f"last_time={utc_now().isoformat()}\nreason={reason}\ncount={count}\n",
        encoding="utf-8",
    )


def clear_failure(state_dir: Path, device: str) -> None:
    try:
        state_file(state_dir, device).unlink()
    except FileNotFoundError:
        pass


def read_failures_summary(state_dir: Path) -> list[tuple[str, str, str, str]]:
    """
    Returns list of (device, last_time, reason, count).
    Best-effort; safe if files missing/partial.
    """
    out: list[tuple[str, str, str, str]] = []
    try:
        if not state_dir.exists():
            return out
        for p in sorted(state_dir.glob("*.failure")):
            dev = p.stem
            last_time = "-"
            reason = "-"
            count = "-"
            try:
                for line in p.read_text(encoding="utf-8").splitlines():
                    if line.startswith("last_time="):
                        last_time = line.split("=", 1)[1].strip()
                    elif line.startswith("reason="):
                        reason = line.split("=", 1)[1].strip()
                    elif line.startswith("count="):
                        count = line.split("=", 1)[1].strip()
            except Exception:
                pass
            out.append((dev, last_time, reason, count))
    except Exception:
        return out
    return out


# ----------------------------
# Auto-ignore perms (state/<device>.autoexclude)
# ----------------------------

def autoexclude_file(state_dir: Path, device: str) -> Path:
    return state_dir / f"{device}.autoexclude"


def load_autoexclude_patterns(state_dir: Path, device: str) -> list[str]:
    p = autoexclude_file(state_dir, device)
    try:
        if not p.exists():
            return []
        lines = []
        for line in p.read_text(encoding="utf-8").splitlines():
            s = line.strip()
            if not s or s.startswith("#"):
                continue
            lines.append(s)
        return lines
    except Exception:
        return []


def save_autoexclude_patterns(
    state_dir: Path,
    device: str,
    new_patterns: list[str],
    *,
    max_total: int,
) -> tuple[int, int]:
    """
    Merge and persist patterns. Returns (added, total_after).
    Best-effort and robust.
    """
    safe_mkdir(state_dir, parents=True)
    p = autoexclude_file(state_dir, device)
    existing = load_autoexclude_patterns(state_dir, device)
    seen = set(existing)

    added = 0
    merged = list(existing)
    for pat in new_patterns:
        if pat in seen:
            continue
        if max_total > 0 and len(merged) >= max_total:
            break
        merged.append(pat)
        seen.add(pat)
        added += 1
        if max_total > 0 and len(merged) >= max_total:
            break

    try:
        header = [
            "# pull-backup autoexclude (permission denied paths)",
            f"# device={device}",
            f"# updated_utc={utc_now().isoformat()}",
            "",
        ]
        p.write_text("\n".join(header + merged) + "\n", encoding="utf-8")
    except Exception:
        return (0, len(existing))

    return (added, len(merged))


# ----------------------------
# Ledger (state/runs.jsonl)
# ----------------------------

def ledger_path(state_dir: Path) -> Path:
    return state_dir / "runs.jsonl"


def append_ledger(state_dir: Path, record: dict[str, Any]) -> None:
    try:
        safe_mkdir(state_dir, parents=True)
        lp = ledger_path(state_dir)
        line = json.dumps(record, sort_keys=True)
        with open(lp, "a", encoding="utf-8") as fp:
            fp.write(line + "\n")
    except Exception:
        # ledger must never break backup runs
        pass


def read_last_success_map(state_dir: Path) -> dict[str, dt.datetime]:
    """
    Return map device -> last successful end time (UTC) from runs.jsonl.
    Best-effort and bounded (tail scan).
    """
    lp = ledger_path(state_dir)
    if not lp.exists():
        return {}
    out: dict[str, dt.datetime] = {}
    try:
        # tail-ish: read last ~2MB
        max_bytes = 2 * 1024 * 1024
        with open(lp, "rb") as fp:
            fp.seek(0, os.SEEK_END)
            size = fp.tell()
            start = max(0, size - max_bytes)
            fp.seek(start, os.SEEK_SET)
            data = fp.read().decode("utf-8", errors="replace")
        for line in data.splitlines():
            line = line.strip()
            if not line or not line.startswith("{"):
                continue
            try:
                rec = json.loads(line)
            except Exception:
                continue
            if rec.get("type") != "job":
                continue
            if rec.get("outcome") != "success":
                continue
            dev = str(rec.get("device", "")).strip()
            end = str(rec.get("ts_end", "")).strip()
            if not dev or not end:
                continue
            try:
                d = dt.datetime.fromisoformat(end.replace("Z", "+00:00")).astimezone(dt.timezone.utc)
            except Exception:
                continue
            cur = out.get(dev)
            if cur is None or d > cur:
                out[dev] = d
    except Exception:
        return out
    return out


# ----------------------------
# Retention + log pruning
# ----------------------------

def prune_logs(log_dir: Path, keep_days: int) -> None:
    cutoff = utc_now() - dt.timedelta(days=keep_days)
    try:
        paths = list(log_dir.glob("backup-*.log"))
    except OSError as e:
        if _is_bad_fs_error(e):
            return
        raise
    for p in paths:
        try:
            mtime = dt.datetime.fromtimestamp(p.stat().st_mtime, tz=dt.timezone.utc)
            if mtime < cutoff:
                p.unlink()
        except Exception:
            pass


def retention(snap_dir: Path, legacy_root: Path, keep: int, action: str, log) -> None:
    snaps = sorted([p for p in safe_list_dirs(snap_dir) if p.name.startswith("20")])
    if len(snaps) <= keep:
        return
    old = snaps[: len(snaps) - keep]
    log.state("RETENTION_SCAN", f"found {len(old)} snapshots older than keep={keep}")

    act = (action or "").strip().lower()
    # Back-compat: "quarantine" now means "legacy"
    if act == "quarantine":
        act = "legacy"

    if act == "keep":
        log.state("RETENTION", "action=keep (leaving older snapshots)")
        return

    if act == "legacy":
        safe_mkdir(legacy_root, parents=True)
        for d in old:
            dst = legacy_root / d.name
            log.state("RETENTION", f"legacy {d.name} -> {dst}")
            d.rename(dst)
        return

    if act == "delete":
        for d in old:
            log.state("RETENTION", f"delete {d.name}")
            shutil.rmtree(d)
        return

    raise RuntimeError(f"unknown retention action: {action}")


# ----------------------------
# SSH helpers (reachability = rsync-ready)
# ----------------------------

def ssh_cmd_base(ssh_config: Optional[Path]) -> list[str]:
    base = [
        "ssh",
        "-o", "BatchMode=yes",
        "-o", "ConnectTimeout=8",
        "-o", "ServerAliveInterval=5",
        "-o", "ServerAliveCountMax=2",
    ]
    if ssh_config and ssh_config.exists():
        base += ["-F", str(ssh_config)]
    return base


def run_quick(cmd: list[str], *, timeout_s: int = 15) -> tuple[int, str]:
    try:
        p = subprocess.run(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=timeout_s,
        )
        return p.returncode, (p.stdout or "")
    except subprocess.TimeoutExpired as e:
        out = ""
        if e.stdout:
            out = str(e.stdout)
        return 124, out + ("\n[local] probe timed out\n")


def rsync_ready_probe(host: str, ssh_config: Optional[Path], *, timeout_s: int = 15) -> tuple[bool, str]:
    cmd = ssh_cmd_base(ssh_config) + [host, "command -v rsync >/dev/null 2>&1 && echo RSYNC_OK"]
    rc, out = run_quick(cmd, timeout_s=timeout_s)
    ok = (rc == 0) and ("RSYNC_OK" in out)
    return ok, out


# ----------------------------
# Resumable run tag + detection
# ----------------------------

def _inprogress_payload_present(inprog: Path) -> bool:
    """
    True if this in-progress dir looks like it has "real" payload (not just tag/partials dir).
    Used to detect resumable work without mutating anything.
    """
    try:
        if not inprog.exists() or not inprog.is_dir():
            return False
        allowed = {".run-tag", ".rsync-partial"}
        for p in inprog.iterdir():
            if p.name in allowed:
                continue
            return True
        return False
    except Exception:
        return False


def has_resumable_inprogress(snap_dir: Path, device: str) -> tuple[bool, Optional[str]]:
    """
    Non-mutating check used during PREFLIGHT to prioritize resumes.
    Returns (has_resume, tag_hint).
    """
    inprog = snap_dir / f".inprogress-{device}"
    tagf = inprog / ".run-tag"
    try:
        if tagf.exists():
            tag = tagf.read_text(encoding="utf-8").strip()
            if tag:
                return True, tag
        if _inprogress_payload_present(inprog):
            return True, None
    except Exception:
        pass
    return False, None


def load_or_create_run_tag(inprog: Path) -> tuple[str, bool, bool]:
    """
    Returns (tag, resumed, created_now)
      - resumed=True means we are resuming a prior in-progress directory.
      - created_now=True means we created .run-tag during this invocation.
    """
    tag_file = inprog / ".run-tag"
    if tag_file.exists():
        try:
            tag = tag_file.read_text(encoding="utf-8").strip()
            if tag:
                return tag, True, False
        except Exception:
            pass

    resumed = _inprogress_payload_present(inprog)
    tag = utc_tag()
    safe_mkdir(inprog, parents=True)
    try:
        tag_file.write_text(tag + "\n", encoding="utf-8")
    except Exception:
        pass
    return tag, resumed, True


def clear_run_tag_in_tree(tree: Path) -> None:
    try:
        (tree / ".run-tag").unlink(missing_ok=True)
    except Exception:
        pass


def cleanup_new_empty_inprogress(inprog: Path) -> None:
    """
    Best-effort cleanup if we created an in-progress dir/tag this run but did not transfer anything.
    Only removes if it looks empty-ish (i.e., no real payload).
    """
    try:
        tagf = inprog / ".run-tag"
        entries = [p.name for p in inprog.iterdir()]
        allowed = {".run-tag", ".rsync-partial"}
        if all(n in allowed for n in entries):
            try:
                tagf.unlink(missing_ok=True)
            except Exception:
                pass
            rp = inprog / ".rsync-partial"
            if rp.exists():
                shutil.rmtree(rp, ignore_errors=True)
            inprog.rmdir()
    except Exception:
        pass


# ----------------------------
# Dual logger
# ----------------------------

class DualLogger:
    def __init__(self, *, job: str, log_fp):
        self.job = job
        self.fp = log_fp

    def _emit(self, line: str) -> None:
        if not line.endswith("\n"):
            line += "\n"
        sys.stdout.write(line)
        sys.stdout.flush()
        self.fp.write(line)
        self.fp.flush()

    def state(self, state: str, msg: str) -> None:
        ts = utc_now().strftime("%F %T")
        self._emit(f"[{ts} UTC] [{self.job}] {state}: {msg}")

    def raw(self, text: str) -> None:
        if text == "":
            return
        if not text.endswith("\n"):
            text += "\n"
        sys.stdout.write(text)
        sys.stdout.flush()
        self.fp.write(text)
        self.fp.flush()


# ----------------------------
# Progress helpers (bytes so far)
# ----------------------------

def _fmt_bytes(n: int) -> str:
    units = ["B", "KiB", "MiB", "GiB", "TiB", "PiB"]
    x = float(n)
    for u in units:
        if x < 1024.0:
            if u == "B":
                return f"{int(x)}{u}"
            return f"{x:.2f}{u}"
        x /= 1024.0
    return f"{x:.2f}EiB"


def du_bytes(path: Path, *, timeout_s: int) -> tuple[Optional[int], str]:
    """
    Returns (bytes, status) using `du -sb`.
      - status: "ok" | "timeout" | "error" | "missing"
    """
    try:
        p = subprocess.run(
            ["du", "-sb", str(path)],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=timeout_s,
        )
        if p.returncode != 0:
            return None, "error"
        first = (p.stdout or "").strip().split(None, 1)[0]
        return int(first), "ok"
    except FileNotFoundError:
        return None, "missing"
    except subprocess.TimeoutExpired:
        return None, "timeout"
    except ValueError:
        return None, "error"

def adaptive_du_timeout(base_s: int, bytes_hint: Optional[int], consecutive_timeouts: int = 0) -> int:
    """
    Dynamically increase du timeout as the in-progress tree grows.

    - base_s is the user-configured floor (--du-timeout-s).
    - We scale with log2(size) so it grows gently.
    - Hard-capped to stay safe.
    - If du times out, apply exponential backoff per timeout to quickly reach a workable value.
    """
    base = max(1, int(base_s))
    b = max(0, int(bytes_hint or 0))
    hard_cap = max(base, min(180, base * 6))
    if b <= 0:
        # still allow timeout backoff even with unknown size
        if consecutive_timeouts > 0:
            backoff = int(round(base * (1.7 ** min(8, consecutive_timeouts))))
            return max(base, min(hard_cap, backoff))
        return base
    gib = 1024 ** 3
    steps = math.log2(1.0 + (b / gib))
    scaled = int(round(base * (1.0 + 0.35 * steps)))
    if consecutive_timeouts > 0:
        scaled = int(round(scaled * (1.7 ** min(8, consecutive_timeouts))))
    return max(base, min(hard_cap, scaled))


# ----------------------------
# Signal-safe runner (process group) + stall watchdog
# ----------------------------

class _Runner:
    def __init__(self) -> None:
        self.child_pgid: Optional[int] = None
        self.signal_seen: Optional[int] = None


RUNNER = _Runner()


def _forward_signal(sig: int, _frame) -> None:
    RUNNER.signal_seen = sig
    if RUNNER.child_pgid is not None:
        try:
            os.killpg(RUNNER.child_pgid, sig)
        except ProcessLookupError:
            pass


def _kill_pgrp(pgid: int, sig: int) -> None:
    try:
        os.killpg(pgid, sig)
    except ProcessLookupError:
        pass


def run_and_tee(
    cmd: list[str],
    log: DualLogger,
    *,
    kill_grace_s: int = 20,
    wallclock_timeout_s: int = 0,
    progress_path: Optional[Path] = None,
    progress_interval_s: int = 60,
    stall_timeout_s: int = 1800,
    du_timeout_s: int = 20,
    enable_progress: bool = True,
    on_line: Optional[Callable[[str], None]] = None,
) -> tuple[int, Optional[int], str, int]:
    """
    Runs cmd, tees stdout+stderr into DualLogger.

    Adds:
      - Periodic PROGRESS logging based on bytes in progress_path.
      - Stall watchdog: triggers ONLY if BOTH:
          * no dest byte growth, AND
          * no rsync output activity
        for stall_timeout_s seconds.

    Returns: (rc, signal_seen, reason, stall_kills)
    """
    import selectors

    old_int = signal.getsignal(signal.SIGINT)
    old_term = signal.getsignal(signal.SIGTERM)
    signal.signal(signal.SIGINT, _forward_signal)
    signal.signal(signal.SIGTERM, _forward_signal)

    start = time.time()
    last_progress_log = 0.0
    last_bytes: Optional[int] = None
    last_change = time.time()
    last_output_time = time.time()
    du_timeouts = 0

    reason = "unknown"
    rc = 1
    sig_seen: Optional[int] = None
    stall_kills = 0

    sel: Optional[selectors.BaseSelector] = None
    p: Optional[subprocess.Popen[str]] = None

    try:
        p = subprocess.Popen(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            bufsize=1,
            start_new_session=True,
        )
        assert p.stdout is not None
        RUNNER.child_pgid = os.getpgid(p.pid)
        RUNNER.signal_seen = None

        sel = selectors.DefaultSelector()
        sel.register(p.stdout, selectors.EVENT_READ)

        def _note_output(line: str) -> None:
            nonlocal last_output_time
            last_output_time = time.time()
            if on_line is not None:
                try:
                    on_line(line)
                except Exception:
                    pass

        while True:
            if p.poll() is not None:
                try:
                    rest = p.stdout.read()
                    if rest:
                        rest = rest.replace("\r", "\n")
                        log.raw(rest)
                        for ln in rest.splitlines():
                            _note_output(ln)
                except Exception:
                    pass
                break

            now = time.time()

            if wallclock_timeout_s > 0 and (now - start) > wallclock_timeout_s:
                reason = "wallclock_timeout"
                log.state("RUN_TIMEOUT", f"wallclock timeout exceeded ({wallclock_timeout_s}s); terminating rsync")
                _kill_pgrp(RUNNER.child_pgid, signal.SIGTERM)
                t0 = time.time()
                while time.time() - t0 < kill_grace_s:
                    if p.poll() is not None:
                        break
                    time.sleep(0.2)
                if p.poll() is None:
                    log.state("RUN_TIMEOUT", "rsync did not exit after SIGTERM; sending SIGKILL")
                    _kill_pgrp(RUNNER.child_pgid, signal.SIGKILL)
                break

            if enable_progress and progress_path and progress_interval_s > 0 and (now - last_progress_log) >= progress_interval_s:
                du_to = adaptive_du_timeout(du_timeout_s, last_bytes, du_timeouts)
                b, du_status = du_bytes(progress_path, timeout_s=du_to)
                if b is not None and du_status == "ok":
                    du_timeouts = 0
                    if last_bytes is None:
                        last_bytes = b
                        last_change = now
                    else:
                        if b > last_bytes:
                            last_change = now
                        delta = b - last_bytes
                        elapsed = max(1e-6, (now - last_progress_log) if last_progress_log > 0 else (now - start))
                        rate = delta / elapsed
                        last_bytes = b
                        log.state(
                            "PROGRESS",
                            f"bytes={_fmt_bytes(b)} rate={_fmt_bytes(int(rate))}/s "
                            f"stall_for={int(now - last_change)}s out_idle={int(now - last_output_time)}s du_timeout={du_to}s",
                        )

                    if stall_timeout_s > 0:
                        # Only trust "no growth" if we have a valid byte measurement.
                        no_growth = (last_bytes is not None) and ((now - last_change) >= stall_timeout_s)
                        no_output = (now - last_output_time) >= stall_timeout_s
                        if no_growth and no_output:
                            reason = "stall_timeout"
                            stall_kills += 1
                            log.state(
                                "RUN_STALL",
                                f"no byte growth AND no rsync output for {stall_timeout_s}s -> terminating rsync",
                            )
                            _kill_pgrp(RUNNER.child_pgid, signal.SIGTERM)
                            t0 = time.time()
                            while time.time() - t0 < kill_grace_s:
                                if p.poll() is not None:
                                    break
                                time.sleep(0.2)
                            if p.poll() is None:
                                log.state("RUN_STALL", "rsync did not exit after SIGTERM; sending SIGKILL")
                                _kill_pgrp(RUNNER.child_pgid, signal.SIGKILL)
                            break
                else:
                    if du_status == "timeout":
                        du_timeouts += 1
                    log.state(
                        "PROGRESS",
                        f"du_bytes unavailable status={du_status} consecutive_timeouts={du_timeouts} du_timeout={du_to}s",
                    )

                last_progress_log = now

            assert sel is not None
            events = sel.select(timeout=0.5)
            if not events:
                continue

            for key, _mask in events:
                try:
                    chunk = key.fileobj.readline()
                except Exception:
                    chunk = ""
                if chunk:
                    chunk = chunk.replace("\r", "\n")
                    log.raw(chunk)
                    for ln in chunk.splitlines():
                        _note_output(ln)

        rc = p.wait()
        sig_seen = RUNNER.signal_seen
        if sig_seen is not None:
            reason = f"signal_{sig_seen}"
        elif reason in ("wallclock_timeout", "stall_timeout"):
            if rc == 0:
                rc = 124
        else:
            reason = "exit"

        return rc, sig_seen, reason, stall_kills

    finally:
        if sel is not None:
            try:
                sel.close()
            except Exception:
                pass

        if RUNNER.child_pgid is not None:
            try:
                os.killpg(RUNNER.child_pgid, 0)
            except ProcessLookupError:
                pass
            else:
                _kill_pgrp(RUNNER.child_pgid, signal.SIGTERM)
                t0 = time.time()
                while time.time() - t0 < kill_grace_s:
                    try:
                        os.killpg(RUNNER.child_pgid, 0)
                    except ProcessLookupError:
                        break
                    time.sleep(0.2)
                else:
                    _kill_pgrp(RUNNER.child_pgid, signal.SIGKILL)

        RUNNER.child_pgid = None
        RUNNER.signal_seen = None
        signal.signal(signal.SIGINT, old_int)
        signal.signal(signal.SIGTERM, old_term)


# ----------------------------
# Load-shedding
# ----------------------------

def wait_for_load(max_load: float, log: DualLogger, poll_s: int = 10) -> None:
    if max_load <= 0:
        return
    warned = False
    while True:
        try:
            one, _five, _fifteen = os.getloadavg()
        except OSError:
            return
        if one <= max_load:
            return
        if not warned:
            log.state("LOAD_WAIT", f"loadavg(1m)={one:.2f} > max_load={max_load:.2f}; waiting")
            warned = True
        time.sleep(max(1, poll_s))


# ----------------------------
# Jobs config
# ----------------------------

def _as_list_str(v: Any) -> list[str]:
    if v is None:
        return []
    if isinstance(v, list):
        out: list[str] = []
        for x in v:
            if x is None:
                continue
            s = str(x).strip()
            if s:
                out.append(s)
        return out
    # allow single string
    s = str(v).strip()
    return [s] if s else []


def _is_safe_exclude_pattern(pat: str) -> bool:
    # No absolute paths and no traversal.
    if pat.startswith("/"):
        return False
    parts = [x for x in pat.replace("\\", "/").split("/") if x not in ("", ".")]
    if any(x == ".." for x in parts):
        return False
    return True


def _normalize_abs_exclude_to_root(pat: str, job_path: str) -> str:
    """
    If user provides an absolute path pattern, convert to anchored rsync exclude
    relative to job_path, e.g.:
      job_path=/home/klein/  abs=/home/klein/.foo -> /.foo
    """
    jp = job_path
    if not jp.endswith("/"):
        jp += "/"
    if pat.startswith(jp):
        rel = pat[len(jp):].lstrip("/")
        return f"/{rel}"
    # special case: job_path is "/" (or effectively root)
    if jp == "/" and pat.startswith("/"):
        return pat  # keep absolute anchor
    raise RuntimeError(f"exclude pattern not under job.path: {pat} (job.path={job_path})")


@dataclass(frozen=True)
class Job:
    device: str
    ssh: str
    path: str
    when: str
    description: str
    klass: str
    keep: int
    action: str

    # Back-compat: these must be optional with defaults so old callers/tests can do Job(...)
    exclude: tuple[str, ...] = ()
    exclude_file: str = ""

    stall_timeout_s: int = 0
    progress_interval_s: int = 0
    du_timeout_s: int = 0

    self_backup: bool = False


def parse_jobs(cfg: dict[str, Any], defaults: dict[str, Any]) -> list[Job]:
    jobs_raw = cfg.get("job", [])
    if not isinstance(jobs_raw, list):
        raise RuntimeError("jobs.toml must contain one or more [[job]] tables")
    out: list[Job] = []
    for j in jobs_raw:
        if not isinstance(j, dict):
            continue

        device = str(j.get("device", "")).strip()
        if not device:
            continue

        sshv = str(j.get("ssh", device)).strip()

        path = str(j.get("path", f"/home/{device}/")).strip()
        if not path.endswith("/"):
            path += "/"

        when = str(j.get("when", "daily")).strip()
        desc = str(j.get("description", "")).strip()
        klass = str(j.get("class", defaults["class"])).strip()

        keep = int(j.get("keep", defaults["keep"]))
        if keep < 1:
            keep = 1

        action = str(j.get("action", defaults["action"])).strip()

        # excludes
        excludes_in = _as_list_str(j.get("exclude", []))
        excludes_norm: list[str] = []
        for pat in excludes_in:
            if pat.startswith("/"):
                # allow absolute excludes only if they are under job.path; convert to anchored exclude
                excludes_norm.append(_normalize_abs_exclude_to_root(pat, path))
                continue
            if not _is_safe_exclude_pattern(pat):
                raise RuntimeError(f"unsafe exclude pattern for {device}: {pat!r}")
            excludes_norm.append(pat)

        excl_file = str(j.get("exclude_file", "")).strip()

        # per-job progress/stall overrides (0/None means use global args)
        stall_to = int(j.get("stall_timeout_s", 0) or 0)
        prog_int = int(j.get("progress_interval_s", 0) or 0)
        du_to = int(j.get("du_timeout_s", 0) or 0)

        self_backup = bool(j.get("self_backup", False))

        out.append(
            Job(
                device=device,
                ssh=sshv,
                path=path,
                when=when,
                description=desc,
                klass=klass,
                keep=keep,
                action=action,
                exclude=tuple(excludes_norm),
                exclude_file=excl_file,
                stall_timeout_s=stall_to,
                progress_interval_s=prog_int,
                du_timeout_s=du_to,
                self_backup=self_backup,
            )
        )
    return out


# ----------------------------
# Job outcome + summary
# ----------------------------

class Outcome(Enum):
    SUCCESS = "success"
    SOFT_SUCCESS = "soft_success"
    FAILED = "failed"
    SKIPPED = "skipped"
    DEFERRED = "deferred"


@dataclass
class JobSummary:
    job: Job
    outcome: Outcome
    reason: str
    tag: Optional[str]
    started: Optional[dt.datetime]
    ended: Optional[dt.datetime]
    attempts: int

    # Back-compat: tests construct JobSummary with only the first 7 fields.
    final_rc: Optional[int] = None
    transient_rcs: tuple[int, ...] = ()
    stall_kills: int = 0
    perm_denied_paths: tuple[str, ...] = ()


def _fmt_dur(s: JobSummary) -> str:
    if not s.started or not s.ended:
        return "-"
    sec = (s.ended - s.started).total_seconds()
    if sec < 0:
        return "-"
    if sec < 60:
        return f"{int(sec)}s"
    if sec < 3600:
        return f"{int(sec//60)}m{int(sec%60)}s"
    return f"{int(sec//3600)}h{int((sec%3600)//60)}m"


def _worst_outcome(a: Outcome, b: Outcome) -> Outcome:
    rank = {
        Outcome.FAILED: 5,
        Outcome.DEFERRED: 4,
        Outcome.SOFT_SUCCESS: 3,
        Outcome.SUCCESS: 2,
        Outcome.SKIPPED: 1,
    }
    return a if rank[a] >= rank[b] else b


def collapse_summaries_by_device(summaries: list[JobSummary]) -> list[JobSummary]:
    """
    Collapse multiple entries for the same device into one line-item while preserving
    the "worst" outcome and surfacing all reasons/tags.
    """
    by_dev: dict[str, list[JobSummary]] = {}
    for s in summaries:
        by_dev.setdefault(s.job.device, []).append(s)

    out: list[JobSummary] = []
    for dev, items in sorted(by_dev.items(), key=lambda kv: kv[0]):
        worst = items[0].outcome
        for it in items[1:]:
            worst = _worst_outcome(worst, it.outcome)

        reasons: list[str] = []
        for it in items:
            if it.reason and it.reason not in reasons:
                reasons.append(it.reason)

        tag = None
        for it in items:
            if it.tag:
                tag = it.tag
                break

        # TEST EXPECTATION (and intended semantics): attempts should SUM across entries.
        attempts = sum(max(0, int(it.attempts)) for it in items)

        # Combine ancillary fields conservatively
        final_rc = None
        for it in items:
            if it.final_rc is not None:
                final_rc = it.final_rc

        transient: list[int] = []
        for it in items:
            transient.extend(list(it.transient_rcs))

        stall_kills = sum(int(it.stall_kills) for it in items)

        perm_paths: list[str] = []
        for it in items:
            perm_paths.extend(list(it.perm_denied_paths))

        started_vals = [it.started for it in items if it.started is not None]
        ended_vals = [it.ended for it in items if it.ended is not None]
        started = min(started_vals) if started_vals else None
        ended = max(ended_vals) if ended_vals else None

        rep = items[0].job
        out.append(
            JobSummary(
                rep,
                worst,
                "+".join(reasons) if reasons else worst.value,
                tag,
                started,
                ended,
                attempts,
                final_rc,
                tuple(transient),
                stall_kills,
                tuple(perm_paths),
            )
        )
    return out


def _ascii_table(rows: list[list[str]], headers: list[str]) -> str:
    cols = len(headers)
    widths = [len(h) for h in headers]
    for r in rows:
        for i in range(cols):
            widths[i] = max(widths[i], len(r[i]))

    def sep(ch: str = "-") -> str:
        return "+ " + " + ".join(ch * w for w in widths) + " +"

    def fmt_row(r: list[str]) -> str:
        return "| " + " | ".join(r[i].ljust(widths[i]) for i in range(cols)) + " |"

    out: list[str] = []
    out.append(sep("-"))
    out.append(fmt_row(headers))
    out.append(sep("="))
    for r in rows:
        out.append(fmt_row(r))
    out.append(sep("-"))
    return "\n".join(out)


# ----------------------------
# Job metadata + ordering
# ----------------------------

@dataclass
class JobMeta:
    resumable: bool
    resumable_tag_hint: Optional[str]
    snap_count: int
    last_snap_dt: Optional[dt.datetime]
    prior_failure: bool
    last_success_dt: Optional[dt.datetime]


def job_snap_dir(backups_root: Path, j: Job) -> Path:
    return backups_root / j.klass / j.device / "snapshots"


def job_legacy_dir(backups_root: Path, j: Job) -> Path:
    return backups_root / "legacy" / j.klass / j.device


def collect_job_meta(
    backups_root: Path,
    state_dir: Path,
    j: Job,
    last_success_map: dict[str, dt.datetime],
) -> JobMeta:
    snap_dir = job_snap_dir(backups_root, j)
    has_r, hint = has_resumable_inprogress(snap_dir, j.device)

    snap_count = 0
    last_dt: Optional[dt.datetime] = None
    try:
        snaps = [p for p in safe_list_dirs(snap_dir) if p.name.startswith("20")]
        snap_count = len(snaps)
        if snaps:
            newest = sorted(snaps, key=lambda p: p.name)[-1].name
            last_dt = parse_utc_tag(newest)
    except Exception:
        pass

    pf = has_prior_failure(state_dir, j.device)
    ls = last_success_map.get(j.device)
    return JobMeta(has_r, hint, snap_count, last_dt, pf, ls)


def priority_tuple(j: Job, m: JobMeta) -> tuple:
    """
    Lower tuple sorts earlier (higher priority).

    Desired:
      1) resumables first
      2) prior failures next
      3) oldest successful backup (ledger) next (older => higher priority)
      4) oldest last snapshot next
      5) fewer snapshots next
      6) stable device name tie-breaker
    """
    now = utc_now()

    if m.last_success_dt is None:
        success_age_sec = 10**12
    else:
        success_age_sec = max(0.0, (now - m.last_success_dt).total_seconds())

    if m.last_snap_dt is None:
        snap_age_sec = 10**12
    else:
        snap_age_sec = max(0.0, (now - m.last_snap_dt).total_seconds())

    return (
        0 if m.resumable else 1,
        0 if m.prior_failure else 1,
        -success_age_sec,
        -snap_age_sec,
        m.snap_count,
        j.device,
    )


# ----------------------------
# Legacy -> archive worker (idle-time)
# ----------------------------

def _which(cmd: str) -> Optional[str]:
    try:
        return shutil.which(cmd)
    except Exception:
        return None


def _iter_legacy_snapshots(backups_root: Path) -> list[tuple[str, str, Path]]:
    """
    Returns list of (klass, device, snapshot_dir_path) for legacy snapshots.
    snapshot_dir_path points to .../legacy/<klass>/<device>/<tag>
    """
    out: list[tuple[str, str, Path]] = []
    legacy_root = backups_root / "legacy"
    try:
        if not legacy_root.exists():
            return out
        for klass_dir in sorted([p for p in legacy_root.iterdir() if p.is_dir()]):
            klass = klass_dir.name
            for dev_dir in sorted([p for p in klass_dir.iterdir() if p.is_dir()]):
                device = dev_dir.name
                for snap in sorted([p for p in dev_dir.iterdir() if p.is_dir() and p.name.startswith("20")]):
                    out.append((klass, device, snap))
    except Exception:
        return out
    return out


def archive_legacy_on_idle(
    backups_root: Path,
    *,
    state_dir: Path,
    level: int,
    max_items: int,
    max_total_bytes: int,
    du_timeout_s: int,
    max_load: float,
) -> None:
    ts = utc_now().strftime("%F %T")

    if _which("tar") is None or _which("zstd") is None:
        print(f"[{ts} UTC] [idle] ARCHIVE: tar/zstd not available; skipping legacy archive worker")
        return

    # lightweight load-shedding (no DualLogger here)
    if max_load > 0:
        try:
            one, _five, _fifteen = os.getloadavg()
            if one > max_load:
                print(f"[{ts} UTC] [idle] ARCHIVE: loadavg(1m)={one:.2f} > max_load={max_load:.2f}; skipping")
                return
        except OSError:
            pass

    archives_root = backups_root / "archives"
    legacy_items = _iter_legacy_snapshots(backups_root)
    if not legacy_items:
        print(f"[{ts} UTC] [idle] ARCHIVE: no legacy snapshots found")
        return

    def key_item(item: tuple[str, str, Path]) -> tuple:
        _klass, _dev, p = item
        d = parse_utc_tag(p.name)
        if d is not None:
            return (0, d)
        try:
            return (1, dt.datetime.fromtimestamp(p.stat().st_mtime, tz=dt.timezone.utc))
        except Exception:
            return (2, dt.datetime(1970, 1, 1, tzinfo=dt.timezone.utc))

    legacy_items.sort(key=key_item)

    done = 0
    used_bytes = 0

    for klass, dev, snapdir in legacy_items:
        if max_items > 0 and done >= max_items:
            break

        est, _st = du_bytes(snapdir, timeout_s=du_timeout_s)
        est = est or 0

        if max_total_bytes > 0 and (used_bytes + est) > max_total_bytes and done > 0:
            print(f"[{ts} UTC] [idle] ARCHIVE: budget reached; stopping (used={used_bytes}B cap={max_total_bytes}B)")
            break

        out_dir = archives_root / klass / dev
        safe_mkdir(out_dir, parents=True)

        dest = out_dir / f"{snapdir.name}.tar.zst"
        tmp = out_dir / f".{snapdir.name}.tar.zst.tmp"

        if dest.exists():
            try:
                if dest.stat().st_size > 0:
                    print(f"[{ts} UTC] [idle] ARCHIVE: already archived {dest}; removing legacy {snapdir}")
                    shutil.rmtree(snapdir, ignore_errors=True)
                    append_ledger(state_dir, {
                        "type": "archive",
                        "ts": utc_now().isoformat().replace("+00:00", "Z"),
                        "class": klass,
                        "device": dev,
                        "tag": snapdir.name,
                        "outcome": "already_archived_removed_legacy",
                        "archive_path": str(dest),
                    })
                    done += 1
                    continue
            except Exception:
                pass

        parent = snapdir.parent
        tagname = snapdir.name

        print(f"[{ts} UTC] [idle] ARCHIVE: {klass}/{dev}/{tagname} -> {dest} (zstd level {level})")

        try:
            if tmp.exists():
                tmp.unlink()
        except Exception:
            pass

        tar_cmd = ["tar", "-C", str(parent), "-cf", "-", tagname]
        zstd_cmd = ["zstd", f"-{int(level)}", "-T0", "-q", "-o", str(tmp)]

        try:
            p1 = subprocess.Popen(tar_cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
            assert p1.stdout is not None
            p2 = subprocess.Popen(zstd_cmd, stdin=p1.stdout, stdout=subprocess.DEVNULL, stderr=subprocess.PIPE)
            p1.stdout.close()

            _t_err = p1.stderr.read().decode("utf-8", errors="replace") if p1.stderr else ""
            _z_err = p2.stderr.read().decode("utf-8", errors="replace") if p2.stderr else ""

            rc1 = p1.wait()
            rc2 = p2.wait()

            if rc1 != 0 or rc2 != 0:
                print(f"[{ts} UTC] [idle] ARCHIVE: FAILED rc_tar={rc1} rc_zstd={rc2}")
                if _t_err.strip():
                    print(f"[{ts} UTC] [idle] ARCHIVE: tar stderr: {_t_err.strip()}")
                if _z_err.strip():
                    print(f"[{ts} UTC] [idle] ARCHIVE: zstd stderr: {_z_err.strip()}")
                try:
                    tmp.unlink(missing_ok=True)
                except Exception:
                    pass
                append_ledger(state_dir, {
                    "type": "archive",
                    "ts": utc_now().isoformat().replace("+00:00", "Z"),
                    "class": klass,
                    "device": dev,
                    "tag": tagname,
                    "outcome": "failed",
                    "rc_tar": rc1,
                    "rc_zstd": rc2,
                })
                continue

            try:
                if tmp.stat().st_size <= 0:
                    print(f"[{ts} UTC] [idle] ARCHIVE: FAILED produced empty archive; keeping legacy {snapdir}")
                    tmp.unlink(missing_ok=True)
                    append_ledger(state_dir, {
                        "type": "archive",
                        "ts": utc_now().isoformat().replace("+00:00", "Z"),
                        "class": klass,
                        "device": dev,
                        "tag": tagname,
                        "outcome": "failed_empty_archive",
                    })
                    continue
            except Exception:
                pass

            try:
                tmp.replace(dest)
            except Exception:
                shutil.copy2(tmp, dest)
                tmp.unlink(missing_ok=True)

            shutil.rmtree(snapdir, ignore_errors=True)

            used_bytes += est
            done += 1

            append_ledger(state_dir, {
                "type": "archive",
                "ts": utc_now().isoformat().replace("+00:00", "Z"),
                "class": klass,
                "device": dev,
                "tag": tagname,
                "outcome": "success",
                "archive_path": str(dest),
                "estimated_bytes": est,
                "zstd_level": int(level),
            })

        except Exception as e:
            print(f"[{ts} UTC] [idle] ARCHIVE: exception: {e}")
            try:
                tmp.unlink(missing_ok=True)
            except Exception:
                pass
            append_ledger(state_dir, {
                "type": "archive",
                "ts": utc_now().isoformat().replace("+00:00", "Z"),
                "class": klass,
                "device": dev,
                "tag": tagname,
                "outcome": "exception",
                "error": str(e),
            })
            continue

    if done > 0:
        print(f"[{ts} UTC] [idle] ARCHIVE: completed {done} item(s)")
    else:
        print(f"[{ts} UTC] [idle] ARCHIVE: no items archived this run")


