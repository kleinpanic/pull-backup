# ----------------------------
# FS error helpers
# ----------------------------

_FS_BAD_ERRNOS = {errno.ENODEV, errno.ESTALE, errno.EIO}


def _is_bad_fs_error(e: BaseException) -> bool:
    return isinstance(e, OSError) and getattr(e, "errno", None) in _FS_BAD_ERRNOS


def _bad_fs(msg: str) -> RuntimeError:
    return RuntimeError(msg)


def safe_mkdir(path: Path, *, parents: bool = False) -> None:
    try:
        path.mkdir(parents=parents, exist_ok=True)
    except OSError as e:
        if _is_bad_fs_error(e):
            raise _bad_fs(
                f"backup filesystem not available at {path} (stale mount / missing device)"
            )
        raise
    except Exception as e:
        try:
            _ = os.stat(str(path))
        except OSError as oe:
            if _is_bad_fs_error(oe):
                raise _bad_fs(
                    f"backup filesystem not available at {path} (stale mount / missing device)"
                )
        raise e


def statvfs_free_bytes(path: Path) -> int:
    try:
        st = os.statvfs(str(path))
    except OSError as e:
        if _is_bad_fs_error(e):
            raise _bad_fs(
                f"backup filesystem not available at {path} (stale mount / missing device)"
            )
        raise
    return st.f_frsize * st.f_bavail


def assert_backups_root_ready(backups_root: Path) -> None:
    try:
        if not backups_root.exists():
            raise RuntimeError(f"backups root does not exist: {backups_root}")
        if not backups_root.is_dir():
            raise RuntimeError(f"backups root is not a directory: {backups_root}")
    except OSError as e:
        if _is_bad_fs_error(e):
            raise _bad_fs(
                f"backup filesystem not available at {backups_root} (stale mount / missing device)"
            )
        raise
    _ = statvfs_free_bytes(backups_root)


def safe_list_dirs(dirpath: Path) -> list[Path]:
    try:
        return [p for p in dirpath.iterdir() if p.is_dir()]
    except OSError as e:
        if _is_bad_fs_error(e):
            raise _bad_fs(
                f"backup filesystem not available while listing {dirpath} ({e})"
            )
        raise


def ensure_under(root: Path, p: Path) -> None:
    root = root.resolve()
    p = p.resolve(strict=False)
    try:
        p.relative_to(root)
    except ValueError:
        raise RuntimeError(f"path escapes root: {p} (root={root})")


