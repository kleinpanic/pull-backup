# Notifications (opt-in)
# ----------------------------

def _has_gui_env() -> bool:
    # Minimal heuristics; systemd timer as root usually lacks these.
    return bool(os.environ.get("DISPLAY") or os.environ.get("WAYLAND_DISPLAY")) and bool(
        os.environ.get("DBUS_SESSION_BUS_ADDRESS")
    )


def try_notify(title: str, body: str, *, log: Optional[DualLogger] = None) -> None:
    ts = utc_now().strftime("%F %T")
    if _which("notify-send") is None:
        if log:
            log.state("NOTIFY_SKIP", "notify-send not installed")
        else:
            print(f"[{ts} UTC] [notify] NOTIFY_SKIP: notify-send not installed")
        return
    if not _has_gui_env():
        if log:
            log.state("NOTIFY_SKIP", "no DISPLAY/WAYLAND+DBUS session found")
        else:
            print(f"[{ts} UTC] [notify] NOTIFY_SKIP: no DISPLAY/WAYLAND+DBUS session found")
        return
    try:
        subprocess.run(["notify-send", title, body], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, timeout=3)
    except Exception:
        if log:
            log.state("NOTIFY_SKIP", "notify-send failed")
        else:
            print(f"[{ts} UTC] [notify] NOTIFY_SKIP: notify-send failed")


# ----------------------------
# rsync output classification (permission denied)
# ----------------------------

# Examples:
# rsync: [sender] send_files failed to open "...": Permission denied (13)
# rsync: [sender] opendir "...": Permission denied (13)
_PERM_DENIED_RE = re.compile(
    r"""(?x)
    (?:send_files\s+failed\s+to\s+open|opendir)\s+
    "(?P<path>[^"]+)"\s*:\s*Permission\s+denied\s+\(13\)
    """
)

# Other errors we consider "not purely permission denied"
_OTHER_ERR_HINTS = (
    "rsync error:",
    "failed:",
    "IO error",
    "connection unexpectedly closed",
    "error in socket IO",
    "recv_generator",
    "sender " "terminated",
    "file has vanished",
    "mkstemp",
    "rename",
    "chmod",
    "chown",
    "set times",
    "xattr",
    "acl",
)


def _extract_perm_denied_path(line: str) -> Optional[str]:
    m = _PERM_DENIED_RE.search(line)
    if not m:
        return None
    return m.group("path")


def _is_other_error_line(line: str) -> bool:
    s = line.strip()
    if not s:
        return False
    # If it's a perm denied line, not "other"
    if _extract_perm_denied_path(s) is not None:
        return False
    low = s.lower()
    for h in _OTHER_ERR_HINTS:
        if h.lower() in low:
            return True
    return False


def _make_runtime_exclude_for_denied_path(denied_abs_path: str, job_path: str) -> Optional[str]:
    """
    Convert an absolute denied path into an anchored rsync exclude pattern
    relative to job_path.

    Returns pattern like "/.config/foo" (anchored at transfer root),
    or None if it can't be made safe.
    """
    jp = job_path
    if not jp.endswith("/"):
        jp += "/"

    p = denied_abs_path.strip()
    if not p:
        return None

    # If rsync prints a relative path, keep it if safe.
    if not p.startswith("/"):
        if not _is_safe_exclude_pattern(p):
            return None
        # anchor relative paths at root for exact match
        return f"/{p.lstrip('/')}"

    # Absolute path: must be under job_path unless job_path is root
    if jp == "/":
        rel = p.lstrip("/")
        if not _is_safe_exclude_pattern(rel):
            return None
        return f"/{rel}"

    if p.startswith(jp):
        rel = p[len(jp):].lstrip("/")
        if not _is_safe_exclude_pattern(rel):
            return None
        return f"/{rel}"

    return None


# ----------------------------
# Main per-job runner
# ----------------------------

def _is_local_job(job: Job) -> bool:
    hn = ""
    try:
        hn = os.uname().nodename
    except Exception:
        pass
    candidates = {job.device, hn}
    ssh = (job.ssh or "").strip()
    return ssh in ("localhost", "127.0.0.1") or (ssh in candidates and ssh != "")


def _forced_excludes_for_job(job: Job, *, backups_root: Path) -> list[str]:
    """
    Prevent recursion / foot-guns for self-backup (local jobs).
    Returns anchored rsync patterns (may be empty).
    """
    if not _is_local_job(job) and not job.self_backup:
        return []

    # Force-exclude backups root under the selected job.path if possible.
    jp = job.path
    if not jp.endswith("/"):
        jp += "/"
    br = str(backups_root)

    patterns: list[str] = []

    # If job path is root, exclude backups root as "/srv/storage/backups/**"
    if jp == "/":
        rel = br.lstrip("/")
        patterns.append(f"/{rel}/**")
        return patterns

    # If backups_root is under job.path, exclude the relative path within job root
    try:
        if br.startswith(jp):
            rel = br[len(jp):].lstrip("/")
            if rel and _is_safe_exclude_pattern(rel):
                patterns.append(f"/{rel}/**")
    except Exception:
        pass

    # Optional default excludes for self_backup jobs (only when explicitly requested)
    if job.self_backup:
        defaults = [
            "proc/**",
            "sys/**",
            "dev/**",
            "run/**",
            "tmp/**",
            "var/cache/**",
            "var/tmp/**",
        ]
        for d in defaults:
            if _is_safe_exclude_pattern(d):
                patterns.append(f"/{d}")

    return patterns


def run_one_job(
    job: Job,
    *,
    backups_root: Path,
    state_dir: Path,
    ssh_config: Optional[Path],
    args,
) -> JobSummary:
    started = utc_now()

    dev_dir = backups_root / job.klass / job.device
    snap_dir = dev_dir / "snapshots"
    log_dir = dev_dir / "logs"
    inprog = snap_dir / f".inprogress-{job.device}"
    legacy_root = backups_root / "legacy" / job.klass / job.device

    for p in (dev_dir, snap_dir, log_dir, inprog, legacy_root):
        ensure_under(backups_root, p)

    safe_mkdir(log_dir, parents=True)
    safe_mkdir(snap_dir, parents=True)

    tag, resumed, created_now = load_or_create_run_tag(inprog)
    log_file = log_dir / f"backup-{job.device}-{tag}.log"

    attempts = 0
    transient_seen: list[int] = []
    precheck_failures: int = 0
    stall_kills_total = 0
    perm_denied_abs_paths: list[str] = []
    perm_denied_runtime_excludes: list[str] = []
    other_error_lines_seen: int = 0

    final_rc: Optional[int] = None

    with open(log_file, "a" if log_file.exists() else "w", encoding="utf-8") as log_fp:
        log = DualLogger(job=job.device, log_fp=log_fp)
        src = f"{job.ssh}:{job.path}"

        log.state("JOB_START", f"{'resume' if resumed else 'start'} tag={tag} class={job.klass} src={src}")
        if job.description:
            log.state("JOB_INFO", f"description={job.description}")

        deep = bool(args.deep_verify or has_prior_failure(state_dir, job.device))

        snaps = sorted([p for p in safe_list_dirs(snap_dir) if p.name.startswith("20")])
        last_snap = snaps[-1] if snaps else None

        # Effective per-job progress knobs
        eff_stall_to = job.stall_timeout_s if job.stall_timeout_s > 0 else int(args.stall_timeout_s)
        eff_prog_int = job.progress_interval_s if job.progress_interval_s > 0 else int(args.progress_interval_s)
        eff_du_to = job.du_timeout_s if job.du_timeout_s > 0 else int(args.du_timeout_s)

        rsync_opts = [
            "-aHAXx",
            "--numeric-ids",
            "--partial",
            "--partial-dir=.rsync-partial",
            "--info=stats2,name0",
            "--human-readable",
        ]
        if not args.no_compress:
            rsync_opts.append("--compress")

        if args.rsync_timeout and args.rsync_timeout > 0:
            rsync_opts.append(f"--timeout={args.rsync_timeout}")

        if args.rsync_stop_after_mins and args.rsync_stop_after_mins > 0:
            rsync_opts.append(f"--stop-after={args.rsync_stop_after_mins}")

        if args.bwlimit and args.bwlimit > 0:
            rsync_opts.append(f"--bwlimit={args.bwlimit}")

        if deep:
            rsync_opts.append("--checksum")
            log.state("JOB_MODE", "deep-verify enabled (--checksum) due to prior failure or flag")
        if last_snap:
            rsync_opts.append(f"--link-dest={last_snap}")

        safe_mkdir(inprog, parents=True)

        ssh_str = "ssh -o BatchMode=yes -o ConnectTimeout=8 -o ServerAliveInterval=5 -o ServerAliveCountMax=2"
        if ssh_config and ssh_config.exists():
            ssh_str += f" -F {shlex.quote(str(ssh_config))}"

        soft_success_rcs = set() if args.strict_rsync else {23, 24}
        transient_rcs = {12, 30, 35, 255}

        # Excludes: (1) job exclude patterns, (2) job exclude-from, (3) autoexclude file,
        # (4) forced excludes, (5) runtime excludes for perm denied paths.
        forced_excludes = _forced_excludes_for_job(job, backups_root=backups_root)

        autoexclude_enabled = bool(args.auto_ignore_perms)
        autoexclude_patterns = load_autoexclude_patterns(state_dir, job.device) if autoexclude_enabled else []
        autoexclude_path = autoexclude_file(state_dir, job.device) if (autoexclude_enabled and autoexclude_patterns) else None

        def build_cmd(extra_runtime_excludes: list[str]) -> list[str]:
            cmd = ["rsync"] + rsync_opts + ["-e", ssh_str]

            # (1) explicit job excludes
            for pat in job.exclude:
                cmd.append(f"--exclude={pat}")

            # (2) exclude_file from jobs.toml
            if job.exclude_file:
                ef = Path(job.exclude_file)
                if not ef.exists():
                    raise RuntimeError(f"exclude_file not found for {job.device}: {job.exclude_file}")
                cmd.append(f"--exclude-from={str(ef)}")

            # (3) autoexclude file (state)
            if autoexclude_path is not None:
                cmd.append(f"--exclude-from={str(autoexclude_path)}")

            # (4) forced excludes (self/local safety)
            for pat in forced_excludes:
                cmd.append(f"--exclude={pat}")

            # (5) runtime excludes
            for pat in extra_runtime_excludes:
                cmd.append(f"--exclude={pat}")

            cmd += [src, str(inprog) + "/"]
            return cmd

        # Output classifier callback
        def on_rsync_line(line: str) -> None:
            nonlocal other_error_lines_seen
            s = line.strip()
            if not s:
                return

            pth = _extract_perm_denied_path(s)
            if pth is not None:
                perm_denied_abs_paths.append(pth)
                return

            if _is_other_error_line(s):
                other_error_lines_seen += 1

        terminal_ok = False
        soft_succeeded = False
        autoignore_reran = False

        while attempts < max(1, int(args.attempts)):
            attempts += 1

            wait_for_load(args.max_load, log, poll_s=max(1, args.load_poll))

            log.state("RUN_PRECHECK", f"attempt={attempts}: probing (ssh+rsync-ready)")
            ok, out = rsync_ready_probe(job.ssh, ssh_config, timeout_s=args.ssh_probe_timeout)
            if out.strip():
                for line in out.splitlines():
                    log.raw(f"[probe] {line}")

            if not ok:
                precheck_failures += 1
                log.state("RUN_DEFER", f"endpoint not rsync-ready; deferring in this pass (attempt={attempts})")
                mark_failure(state_dir, job.device, "ssh_or_rsync_unreachable")
                prune_logs(log_dir, args.log_days)

                if created_now and not resumed:
                    log.state("CLEANUP", "removing newly-created empty in-progress dir (deferred before transfer)")
                    cleanup_new_empty_inprogress(inprog)

                ended = utc_now()
                reason = "ssh_or_rsync_unreachable"
                if precheck_failures > 1:
                    reason += f" precheck_fails={precheck_failures}"
                return JobSummary(
                    job, Outcome.DEFERRED, reason, tag, started, ended, attempts,
                    final_rc=None, transient_rcs=tuple(transient_seen),
                    stall_kills=stall_kills_total, perm_denied_paths=tuple(),
                )

            # reset per-attempt collectors (but keep accumulated perm-denied list)
            other_error_lines_seen = 0

            cmd = build_cmd(extra_runtime_excludes=perm_denied_runtime_excludes)
            log.state("RUN_START", f"attempt={attempts}: running rsync (cmd below)")
            log.raw("[cmd] " + " ".join(shlex.quote(c) for c in cmd))

            wall_s = int(args.wallclock_timeout_s) if args.wallclock_timeout_s else 0
            rc, sig_seen, why, stalls = run_and_tee(
                cmd,
                log,
                kill_grace_s=args.kill_grace_s,
                wallclock_timeout_s=wall_s,
                progress_path=inprog,
                progress_interval_s=eff_prog_int,
                stall_timeout_s=eff_stall_to,
                du_timeout_s=eff_du_to,
                enable_progress=(not args.no_progress),
                on_line=on_rsync_line,
            )
            stall_kills_total += stalls
            final_rc = rc

            if sig_seen is not None or rc == 20:
                log.state("RUN_INTERRUPTED", f"signal={sig_seen} rc={rc}; leaving partials for resume in {inprog}")
                mark_failure(state_dir, job.device, "interrupted")
                prune_logs(log_dir, args.log_days)
                ended = utc_now()
                return JobSummary(
                    job, Outcome.FAILED, "interrupted", tag, started, ended, attempts,
                    final_rc=final_rc, transient_rcs=tuple(transient_seen),
                    stall_kills=stall_kills_total, perm_denied_paths=tuple(),
                )

            if rc == 0:
                log.state("RUN_OK", f"rsync rc=0 ({why})")
                terminal_ok = True
                break

            # Soft success path: attempt auto-ignore perms rerun once if eligible
            if rc in soft_success_rcs:
                if args.auto_ignore_perms and not autoignore_reran:
                    seen_pat: set[str] = set(perm_denied_runtime_excludes)
                    new_pats: list[str] = []
                    for ap in perm_denied_abs_paths:
                        pat = _make_runtime_exclude_for_denied_path(ap, job.path)
                        if pat and pat not in seen_pat:
                            new_pats.append(pat)
                            seen_pat.add(pat)

                    # eligible if there were permission denieds AND no other error hints
                    if new_pats and other_error_lines_seen == 0:
                        added, total_after = save_autoexclude_patterns(
                            state_dir,
                            job.device,
                            new_pats,
                            max_total=int(args.auto_ignore_max),
                        )
                        log.state("PERM_DENIED", f"auto-ignoring {len(new_pats)} path(s) (added={added} total={total_after})")
                        cap = 20
                        for pth in new_pats[:cap]:
                            log.state("PERM_DENIED", f"exclude {pth}")
                        if len(new_pats) > cap:
                            log.state("PERM_DENIED", f"... {len(new_pats) - cap} more (see {autoexclude_file(state_dir, job.device)})")
                        log.state("PERM_DENIED", f"saved to {autoexclude_file(state_dir, job.device)}")

                        perm_denied_runtime_excludes.extend(new_pats)

                        autoignore_reran = True
                        log.state("RUN_AUTOIGNORE", "re-running rsync once to skip unreadable paths and aim for rc=0")
                        other_error_lines_seen = 0
                        cmd2 = build_cmd(extra_runtime_excludes=perm_denied_runtime_excludes)
                        log.raw("[cmd] " + " ".join(shlex.quote(c) for c in cmd2))
                        rc2, sig2, why2, stalls2 = run_and_tee(
                            cmd2,
                            log,
                            kill_grace_s=args.kill_grace_s,
                            wallclock_timeout_s=wall_s,
                            progress_path=inprog,
                            progress_interval_s=eff_prog_int,
                            stall_timeout_s=eff_stall_to,
                            du_timeout_s=eff_du_to,
                            enable_progress=(not args.no_progress),
                            on_line=on_rsync_line,
                        )
                        stall_kills_total += stalls2
                        final_rc = rc2

                        if sig2 is not None or rc2 == 20:
                            log.state("RUN_INTERRUPTED", f"signal={sig2} rc={rc2}; leaving partials for resume in {inprog}")
                            mark_failure(state_dir, job.device, "interrupted")
                            prune_logs(log_dir, args.log_days)
                            ended = utc_now()
                            return JobSummary(
                                job, Outcome.FAILED, "interrupted", tag, started, ended, attempts,
                                final_rc=final_rc, transient_rcs=tuple(transient_seen),
                                stall_kills=stall_kills_total,
                                perm_denied_paths=tuple(perm_denied_abs_paths),
                            )

                        if rc2 == 0:
                            log.state("RUN_OK", f"rsync rc=0 after auto-ignore ({why2})")
                            terminal_ok = True
                            soft_succeeded = False
                            break

                        rc = rc2

                # If we are here and rc still in soft range, finalize as soft success
                if rc in soft_success_rcs:
                    soft_succeeded = True
                    terminal_ok = True
                    log.state(
                        "RUN_SOFT",
                        f"rsync rc={rc} treated as SOFT_SUCCESS; snapshot will be finalized (may be incomplete)",
                    )
                    mark_failure(state_dir, job.device, f"soft_rsync_rc_{rc}")
                    break

            if rc in transient_rcs:
                transient_seen.append(rc)
                log.state("RUN_RETRY", f"transient rsync rc={rc}; retrying ({attempts}/{args.attempts})")
                mark_failure(state_dir, job.device, f"transient_rsync_rc_{rc}")
                if args.retry_sleep > 0:
                    time.sleep(args.retry_sleep)
                continue

            log.state("RUN_FAIL", f"non-transient rsync rc={rc}; leaving partials in {inprog}")
            mark_failure(state_dir, job.device, f"rsync_rc_{rc}")
            prune_logs(log_dir, args.log_days)
            ended = utc_now()
            reason = f"rsync_rc_{rc}"
            if transient_seen:
                reason += " transient=" + ",".join(str(x) for x in transient_seen)
            return JobSummary(
                job, Outcome.FAILED, reason, tag, started, ended, attempts,
                final_rc=final_rc, transient_rcs=tuple(transient_seen),
                stall_kills=stall_kills_total,
                perm_denied_paths=tuple(perm_denied_abs_paths),
            )

        # ----------------------------
        # Correctness: do NOT finalize unless terminal_ok
        # ----------------------------
        if not terminal_ok:
            reason = f"attempts_exhausted(last_rc={final_rc})"
            log.state("RUN_EXHAUSTED", f"{reason}; leaving partials for resume in {inprog}")
            mark_failure(state_dir, job.device, reason)
            prune_logs(log_dir, args.log_days)
            ended = utc_now()

            append_ledger(state_dir, {
                "type": "job",
                "ts_start": started.isoformat().replace("+00:00", "Z"),
                "ts_end": ended.isoformat().replace("+00:00", "Z"),
                "device": job.device,
                "class": job.klass,
                "tag": tag,
                "outcome": "failed",
                "reason": reason,
                "attempts": attempts,
                "final_rc": final_rc,
                "transient_rcs": transient_seen,
                "stall_kills": stall_kills_total,
                "perm_denied_count": len(perm_denied_abs_paths),
                "perm_denied_sample": perm_denied_abs_paths[:10],
            })

            if args.notify:
                try_notify(
                    f"pull-backup: {job.device} FAILED",
                    f"{reason} (attempts={attempts})",
                    log=log,
                )

            return JobSummary(
                job, Outcome.FAILED, reason, tag, started, ended, attempts,
                final_rc=final_rc, transient_rcs=tuple(transient_seen),
                stall_kills=stall_kills_total,
                perm_denied_paths=tuple(perm_denied_abs_paths),
            )

        # ----------------------------
        # Finalize snapshot (success or soft-success only)
        # ----------------------------
        final = snap_dir / tag
        if final.exists():
            shutil.rmtree(final)

        log.state("FINALIZE", f"renaming in-progress -> final: {inprog} -> {final}")
        inprog.rename(final)
        clear_run_tag_in_tree(final)

        cur = snap_dir / "current"
        try:
            if cur.is_symlink() or cur.exists():
                cur.unlink()
        except FileNotFoundError:
            pass
        cur.symlink_to(final)
        log.state("FINALIZE", f"updated current -> {final}")

        # Retention
        act = (job.action or "").strip().lower()
        if act == "delete" and not args.auto:
            log.state("RETENTION", "action=delete but --auto not set; skipping deletion")
        else:
            retention(snap_dir, legacy_root, job.keep, job.action, log)

        prune_logs(log_dir, args.log_days)

        outcome = Outcome.SOFT_SUCCESS if soft_succeeded else Outcome.SUCCESS
        ended = utc_now()

        snap_bytes, _st = du_bytes(final, timeout_s=max(5, eff_du_to))
        snap_bytes = snap_bytes or None

        if soft_succeeded:
            reason = f"soft_success(rc={final_rc})" if final_rc is not None else "soft_success"
            mark_failure(state_dir, job.device, reason)
        else:
            reason = "success"
            if transient_seen:
                reason += " recovered_from=" + ",".join(str(x) for x in transient_seen)
            clear_failure(state_dir, job.device)

        log.state("JOB_DONE", f"outcome={outcome.value} attempts={attempts}")

        append_ledger(state_dir, {
            "type": "job",
            "ts_start": started.isoformat().replace("+00:00", "Z"),
            "ts_end": ended.isoformat().replace("+00:00", "Z"),
            "device": job.device,
            "class": job.klass,
            "tag": tag,
            "outcome": outcome.value,
            "reason": reason,
            "attempts": attempts,
            "final_rc": final_rc,
            "transient_rcs": transient_seen,
            "stall_kills": stall_kills_total,
            "perm_denied_count": len(perm_denied_abs_paths),
            "perm_denied_sample": perm_denied_abs_paths[:10],
            "snapshot_bytes_est": snap_bytes,
            "autoignore_reran": autoignore_reran,
        })

        if args.notify:
            title = f"pull-backup: {job.device} {outcome.value}"
            body = f"tag={tag} attempts={attempts}"
            if soft_succeeded and final_rc is not None:
                body += f" rc={final_rc}"
            try_notify(title, body, log=log)

        return JobSummary(
            job, outcome, reason, tag, started, ended, attempts,
            final_rc=final_rc, transient_rcs=tuple(transient_seen),
            stall_kills=stall_kills_total,
            perm_denied_paths=tuple(perm_denied_abs_paths),
        )


# ----------------------------
# Main
# ----------------------------

def main() -> int:
    ap = argparse.ArgumentParser(description="Pull backups over SSH (WireGuard), snapshot+retention.")
    ap.add_argument("--daemon", action="store_true", help="run scheduled jobs from jobs.toml")
    ap.add_argument("--jobs-file", default="/etc/pull-backup/jobs.toml")
    ap.add_argument("--backups-root", default="/srv/storage/backups")
    ap.add_argument("--state-dir", default="/var/lib/pull-backup/state")
    ap.add_argument("--class", dest="klass", default="laptops")
    ap.add_argument("--keep", type=int, default=3)
    ap.add_argument(
        "--action",
        choices=["legacy", "quarantine", "delete", "keep"],
        default="quarantine",
        help="retention action; 'quarantine' kept for compatibility but now writes into legacy/",
    )
    ap.add_argument("--log-days", type=int, default=30)
    ap.add_argument("--auto", action="store_true", help="allow destructive actions like retention delete")
    ap.add_argument("--deep-verify", action="store_true", help="force rsync --checksum")
    ap.add_argument("--ssh-config", default="/root/.ssh/config")
    ap.add_argument("--lock-file", default="/run/pull-backup/lock")

    ap.add_argument("--attempts", type=int, default=2)
    ap.add_argument("--retry-sleep", type=int, default=10)
    ap.add_argument("--passes", type=int, default=2)
    ap.add_argument("--pass-delay", type=int, default=120)

    ap.add_argument("--ssh-probe-timeout", type=int, default=12)

    ap.add_argument(
        "--rsync-timeout",
        type=int,
        default=0,
        help="rsync --timeout idle-I/O seconds (0 disables; recommended 0 with stall watchdog)",
    )
    ap.add_argument("--rsync-stop-after-mins", type=int, default=0)
    ap.add_argument("--bwlimit", type=int, default=0)
    ap.add_argument("--no-compress", action="store_true")
    ap.add_argument("--strict-rsync", action="store_true")

    ap.add_argument("--wallclock-timeout-s", type=int, default=0)
    ap.add_argument("--kill-grace-s", type=int, default=20)

    ap.add_argument("--max-load", type=float, default=4.0)
    ap.add_argument("--load-poll", type=int, default=10)

    ap.add_argument("--exit-soft-nonzero", action="store_true")

    ap.add_argument(
        "--ignore-when",
        action="store_true",
        help="ignore job 'when' schedule and run ALL jobs (manual/test force-run)",
    )

    # Resume outside schedule (new name) + back-compat alias flags
    ap.add_argument(
        "--resume-outside-when",
        action="store_true",
        default=True,
        help="attempt resumable jobs even if schedule doesn't match (default on)",
    )
    ap.add_argument(
        "--resume-outside-when-max",
        type=int,
        default=1,
        help="max resumable jobs to run when no jobs match schedule (default 1; 0 = no limit)",
    )

    # Back-compat flags (keep, but hidden-ish in help)
    ap.add_argument("--idle-resume", action="store_true", default=True, help=argparse.SUPPRESS)
    ap.add_argument("--idle-resume-max", type=int, default=1, help=argparse.SUPPRESS)

    ap.add_argument(
        "--archive-legacy-on-idle",
        action="store_true",
        default=True,
        help="when truly idle (no scheduled jobs and no resumables), archive legacy snapshots to archives/ (default on)",
    )
    ap.add_argument("--archive-zstd-level", type=int, default=12)
    ap.add_argument("--archive-max-items", type=int, default=1)
    ap.add_argument("--archive-max-bytes", type=int, default=50 * 1024**3)

    ap.add_argument("--progress-interval-s", type=int, default=60)
    ap.add_argument("--stall-timeout-s", type=int, default=1800)
    ap.add_argument("--du-timeout-s", type=int, default=20)
    ap.add_argument("--no-progress", action="store_true")

    # Auto-ignore permission denied paths
    ap.add_argument(
        "--auto-ignore-perms",
        action="store_true",
        default=True,
        help="auto-ignore unreadable (Permission denied) paths (default on)",
    )
    ap.add_argument(
        "--auto-ignore-max",
        type=int,
        default=200,
        help="cap total autoignored paths per device (default 200; 0 disables cap)",
    )

    # Notifications
    ap.add_argument("--notify", action="store_true", help="send notify-send notifications (opt-in)")

    args = ap.parse_args()
    os.umask(0o077)

    backups_root = Path(args.backups_root).resolve()
    if str(backups_root) != "/srv/storage/backups":
        raise RuntimeError("backups-root must be exactly /srv/storage/backups")
    if not args.daemon:
        raise RuntimeError("Use --daemon (this tool is scheduler-driven).")

    lock_path = Path(args.lock_file)
    safe_mkdir(lock_path.parent, parents=True)

    with open(lock_path, "w") as lock_fp:
        fcntl.flock(lock_fp, fcntl.LOCK_EX)

        assert_backups_root_ready(backups_root)

        state_dir = Path(args.state_dir)
        cfg_path = Path(args.jobs_file)
        defaults = {"class": args.klass, "keep": args.keep, "action": args.action}

        cfg = load_toml(cfg_path)
        jobs_all = parse_jobs(cfg, defaults)

        failures = read_failures_summary(state_dir)
        ts = utc_now().strftime("%F %T")
        if failures:
            print(f"[{ts} UTC] [state] prior failures:")
            for dev, last_time, reason, count in failures:
                print(f"[{ts} UTC] [state]  - {dev}: last_time={last_time} count={count} reason={reason}")

        if args.ignore_when:
            print(f"[{ts} UTC] [daemon] IGNORE_WHEN: running all jobs regardless of schedule")

        last_success_map = read_last_success_map(state_dir)

        metas: dict[str, JobMeta] = {}
        for j in jobs_all:
            metas[j.device] = collect_job_meta(backups_root, state_dir, j, last_success_map)

        ssh_config = Path(args.ssh_config) if args.ssh_config else None

        scheduled: list[Job] = []
        skipped: list[Job] = []
        for j in jobs_all:
            if args.ignore_when or when_matches_today(j.when):
                scheduled.append(j)
            else:
                skipped.append(j)

        resumables: list[Job] = []
        for j in jobs_all:
            m = metas.get(j.device)
            if m and m.resumable:
                resumables.append(j)

        resume_outside = bool(args.resume_outside_when or args.idle_resume)
        resume_cap = int(args.resume_outside_when_max) if args.resume_outside_when_max is not None else int(args.idle_resume_max)

        if args.ignore_when:
            runnable = list(jobs_all)
            skipped = []
        else:
            runnable = []
            seen: set[str] = set()
            for j in scheduled:
                if j.device not in seen:
                    runnable.append(j)
                    seen.add(j.device)

            if resume_outside or scheduled:
                for j in resumables:
                    if j.device not in seen:
                        runnable.append(j)
                        seen.add(j.device)

        if not args.ignore_when:
            ts = utc_now().strftime("%F %T")
            for j in skipped:
                m = metas.get(j.device)
                if m and m.resumable and resume_outside:
                    continue
                print(f"[{ts} UTC] [daemon] skip {j.device} (when={j.when})")

        if not runnable:
            ts = utc_now().strftime("%F %T")
            print(f"[{ts} UTC] [daemon] no jobs to run today (no scheduled and no resumables)")
            if args.archive_legacy_on_idle:
                archive_legacy_on_idle(
                    backups_root,
                    state_dir=state_dir,
                    level=max(1, min(22, int(args.archive_zstd_level))),
                    max_items=max(0, int(args.archive_max_items)),
                    max_total_bytes=max(0, int(args.archive_max_bytes)),
                    du_timeout_s=max(5, int(args.du_timeout_s)),
                    max_load=float(args.max_load),
                )
            if args.notify:
                try_notify("pull-backup: idle", "no jobs; archive worker ran (if enabled)")
            return 0

        if (not args.ignore_when) and (len(scheduled) == 0) and resumables and resume_outside:
            cap = int(resume_cap)
            if cap > 0 and len(runnable) > cap:
                runnable.sort(key=lambda j: priority_tuple(j, metas.get(j.device)))
                runnable = runnable[:cap]
                ts = utc_now().strftime("%F %T")
                print(f"[{ts} UTC] [idle] RESUME_CAP: limiting resumables to {cap} job(s) this run")

        res_list = [j for j in runnable if metas.get(j.device, JobMeta(False, None, 0, None, False, None)).resumable]
        if res_list:
            ts = utc_now().strftime("%F %T")
            for j in res_list:
                m = metas.get(j.device)
                hint = m.resumable_tag_hint if m else None
                hint_s = f" tag_hint={hint}" if hint else ""
                print(f"[{ts} UTC] [run] RESUME_DETECT: {j.device}{hint_s}")

        summaries: list[JobSummary] = []
        if not args.ignore_when:
            for j in skipped:
                m = metas.get(j.device)
                if m and m.resumable and resume_outside:
                    continue
                summaries.append(
                    JobSummary(
                        j, Outcome.SKIPPED, f"when={j.when}", None, None, None, 0,
                        final_rc=None, transient_rcs=tuple(), stall_kills=0, perm_denied_paths=tuple(),
                    )
                )

        passes = max(1, int(args.passes))
        pending: list[Job] = list(runnable)

        for pidx in range(passes):
            pass_no = pidx + 1
            ts = utc_now().strftime("%F %T")
            print(f"[{ts} UTC] [run] PASS_START: {pass_no}/{passes} candidates={len(pending)}")

            if not pending:
                print(f"[{ts} UTC] [run] PASS_EMPTY: nothing to run in pass {pass_no}")
                continue

            print(f"[{ts} UTC] [run] PREFLIGHT: probing {len(pending)} endpoints (ssh+rsync-ready)")
            reachable: list[Job] = []
            unreachable: list[tuple[Job, str]] = []

            for j in pending:
                ok, out = rsync_ready_probe(j.ssh, ssh_config, timeout_s=args.ssh_probe_timeout)
                if ok:
                    reachable.append(j)
                else:
                    reason = "not_rsync_ready"
                    if out.strip():
                        reason = "not_rsync_ready_with_output"
                    unreachable.append((j, reason))

            ts = utc_now().strftime("%F %T")
            print(f"[{ts} UTC] [run] PREFLIGHT: reachable={len(reachable)} unreachable={len(unreachable)}")
            for j, r in unreachable:
                print(f"[{ts} UTC] [run] PREFLIGHT_DEFER: {j.device} ({j.ssh}) reason={r}")

            last_success_map = read_last_success_map(state_dir)
            for j in pending:
                metas[j.device] = collect_job_meta(backups_root, state_dir, j, last_success_map)

            reachable_sorted = sorted(reachable, key=lambda j: priority_tuple(j, metas.get(j.device)))

            ts = utc_now().strftime("%F %T")
            if reachable_sorted:
                print(f"[{ts} UTC] [run] PREFLIGHT_ORDER: reachable run order:")
                for j in reachable_sorted:
                    m = metas.get(j.device)
                    last_snap = m.last_snap_dt.isoformat() if (m and m.last_snap_dt) else "-"
                    last_ok = m.last_success_dt.isoformat() if (m and m.last_success_dt) else "-"
                    flags = []
                    if m and m.resumable:
                        flags.append("RESUME")
                    if m and m.prior_failure:
                        flags.append("PRIOR_FAIL")
                    flags_s = ",".join(flags) if flags else "normal"
                    print(f"[{ts} UTC] [run]  - {j.device} ({flags_s}) snaps={m.snap_count if m else 0} last_snap={last_snap} last_success={last_ok}")

            next_pending: list[Job] = []
            next_pending.extend([j for (j, _r) in unreachable])

            if reachable_sorted:
                for job in reachable_sorted:
                    s = run_one_job(
                        job,
                        backups_root=backups_root,
                        state_dir=state_dir,
                        ssh_config=ssh_config,
                        args=args,
                    )
                    summaries.append(s)

                    if s.outcome == Outcome.DEFERRED and pass_no < passes:
                        next_pending.append(job)

            pending = next_pending

            ts = utc_now().strftime("%F %T")
            print(f"[{ts} UTC] [run] PASS_END: {pass_no}/{passes} deferred_for_next_pass={len(pending)}")

            if pass_no < passes and args.pass_delay > 0 and pending:
                print(f"[{ts} UTC] [run] PASS_SLEEP: sleeping {args.pass_delay}s before next pass")
                time.sleep(args.pass_delay)

        collapsed = collapse_summaries_by_device(summaries)
        hard_fail = any(s.outcome == Outcome.FAILED for s in collapsed)
        soft = any(s.outcome == Outcome.SOFT_SUCCESS for s in collapsed)

        counts = {o: 0 for o in Outcome}
        for s in collapsed:
            counts[s.outcome] += 1

        rows: list[list[str]] = []
        for s in collapsed:
            rows.append([
                s.job.device,
                s.outcome.value,
                str(s.attempts),
                _fmt_dur(s),
                (s.tag or "-"),
                (s.reason or "-"),
            ])

        ts = utc_now().strftime("%F %T")
        print(f"[{ts} UTC] [summary] ------------------------------")
        print(f"[{ts} UTC] [summary] totals: "
              f"success={counts[Outcome.SUCCESS]} "
              f"soft_success={counts[Outcome.SOFT_SUCCESS]} "
              f"failed={counts[Outcome.FAILED]} "
              f"deferred={counts[Outcome.DEFERRED]} "
              f"skipped={counts[Outcome.SKIPPED]}")
        print(_ascii_table(rows, headers=["device", "outcome", "attempts", "dur", "tag", "issues"]))
        print(f"[{ts} UTC] [summary] ------------------------------")

        if args.notify:
            title = "pull-backup: completed"
            body = f"success={counts[Outcome.SUCCESS]} soft={counts[Outcome.SOFT_SUCCESS]} failed={counts[Outcome.FAILED]} deferred={counts[Outcome.DEFERRED]}"
            try_notify(title, body)

        if hard_fail:
            return 1
        if soft and args.exit_soft_nonzero:
            return 2
        return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except RuntimeError as e:
        print(f"[fatal] {e}", file=sys.stderr)
        msg = str(e).lower()
        if "backup filesystem not available" in msg or "stale mount" in msg:
            raise SystemExit(3)
        raise SystemExit(4)
    except Exception as e:
        print(f"[fatal] {e}", file=sys.stderr)
        raise SystemExit(1)

